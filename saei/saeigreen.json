{
  "subtitles": {
    "ar": [
      {
        "start": "00:00:00,000",
        "end": "00:00:02,000",
        "text": "رَبِّ اغْفِرْ وَارْحَمْ"
      },
      {
        "start": "00:00:03,000",
        "end": "00:00:05,000",
        "text": "وَاعْفُ وَتَكَرَّمْ"
      },
      {
        "start": "00:00:06,000",
        "end": "00:00:08,500",
        "text": "وَتَجَاوَزْ عَمَّا تَعْلَمْ"
      },
      {
        "start": "00:00:09,500",
        "end": "00:00:12,000",
        "text": "إِنَّكَ تَعْلَمُ مَا لَا نَعْلَمُ"
      },
      {
        "start": "00:00:13,000",
        "end": "00:00:15,500",
        "text": "إِنَّكَ الْأَعَزُّ الْأَكْرَمُ"
      }
    ],
    "tl": [
      {
        "start": "00:00:00,000",
        "end": "00:00:02,000",
        "text": "Rabbi-ghfir warḥam"
      },
      {
        "start": "00:00:03,000",
        "end": "00:00:05,000",
        "text": "wa'fu wa takarram"
      },
      {
        "start": "00:00:06,000",
        "end": "00:00:08,500",
        "text": "wa tajāwaz 'ammā ta'lam"
      },
      {
        "start": "00:00:09,500",
        "end": "00:00:12,000",
        "text": "innaka ta'lamu mā lā na'lam"
      },
      {
        "start": "00:00:13,000",
        "end": "00:00:15,500",
        "text": "innaka l-a'azzu l-akram"
      }
    ],
    "ms": [
      {
        "start": "00:00:00,000",
        "end": "00:00:02,000",
        "text": "Ya Allah! Ampunilah daku, rahmatilah daku,"
      },
      {
        "start": "00:00:03,000",
        "end": "00:00:05,000",
        "text": "maafkanlah daku dan kurniakan kemuliaan,"
      },
      {
        "start": "00:00:06,000",
        "end": "00:00:08,500",
        "text": "dan ampunilah segala apa yang Engkau ketahui,"
      },
      {
        "start": "00:00:09,500",
        "end": "00:00:12,000",
        "text": "sesungguhnya Engkau mengetahui apa yang kami tidak ketahui,"
      },
      {
        "start": "00:00:13,000",
        "end": "00:00:15,500",
        "text": "sesungguhnya Engkaulah Yang Maha Mulia lagi Maha Terpuji."
      }
    ],
    "en": [
      {
        "start": "00:00:00,000",
        "end": "00:00:02,000",
        "text": "O my Lord! Forgive and have mercy,"
      },
      {
        "start": "00:00:03,000",
        "end": "00:00:05,000",
        "text": "pardon and be generous,"
      },
      {
        "start": "00:00:06,000",
        "end": "00:00:08,500",
        "text": "and overlook what You know,"
      },
      {
        "start": "00:00:09,500",
        "end": "00:00:12,000",
        "text": "Indeed, You know what we do not know,"
      },
      {
        "start": "00:00:13,000",
        "end": "00:00:15,500",
        "text": "Indeed, You are the Most Mighty, the Most Generous."
      }
    ],
    "ml": [
      {
        "start": "00:00:00,000",
        "end": "00:00:02,000",
        "text": "എന്റെ രക്ഷിതാവേ! പൊറുത്തുതരികയും കരുണ കാണിക്കുകയും ചെയ്യേണമേ,"
      },
      {
        "start": "00:00:03,000",
        "end": "00:00:05,000",
        "text": "മാപ്പാക്കുകയും ഉദാരത കാണിക്കുകയും ചെയ്യേണമേ,"
      },
      {
        "start": "00:00:06,000",
        "end": "00:00:08,500",
        "text": "നിനക്കറിയാവുന്ന ഞങ്ങളുടെ പാപങ്ങൾ വിട്ടുവീഴ്ച ചെയ്യേണമേ,"
      },
      {
        "start": "00:00:09,500",
        "end": "00:00:12,000",
        "text": "നിശ്ചയമായും, ഞങ്ങൾക്ക് അറിയാത്തത് നീ അറിയുന്നു,"
      },
      {
        "start": "00:00:13,000",
        "end": "00:00:15,500",
        "text": "നിശ്ചയമായും നീ ഏറ്റവും പ്രതാപിയും ഏറ്റവും ഔദാര്യവാനുമാകുന്നു."
      }
    ],
    "ta": [
      {
        "start": "00:00:00,000",
        "end": "00:00:02,000",
        "text": "என் இறைவா! மன்னித்து அருள் புரிவாயாக,"
      },
      {
        "start": "00:00:03,000",
        "end": "00:00:05,000",
        "text": "மன்னித்து தாராளமாக அருள்வாயாக,"
      },
      {
        "start": "00:00:06,000",
        "end": "00:00:08,500",
        "text": "உனக்குத் தெரிந்த குற்றங்களைப் பொறுத்தருள்வாயாக,"
      },
      {
        "start": "00:00:09,500",
        "end": "00:00:12,000",
        "text": "நிச்சயமாக, எங்களுக்குத் தெரியாததை நீ அறிவாய்,"
      },
      {
        "start": "00:00:13,000",
        "end": "00:00:15,500",
        "text": "நிச்சயமாக நீயே மிகவும் கண்ணியமானவனும், மிக்க கொடையாளியுமாவாய்."
      }
    ]
  }
}