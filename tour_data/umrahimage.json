  "translations": {
    "en": {
      "main_header": "Your Sacred Journey:",
      "main_subheader": "A Step-by-Step Guide to Performing Umrah",
      "badge_purification": "SPIRITUAL AND PHYSICAL PURIFICATION AT HOME",
      "dua_home": "DUA BEFORE LEAVING HOME: Bismillah, tawakkaltu 'ala Allah...",
      "p1_title": "PHASE 1: PREPARATION & DEPARTURE",
      "p1_ghusl": "Ghusl, Nails, Sunnah Safar prayer",
      "check_ghusl": "Ghusl",
      "check_nails": "Nails",
      "check_safar": "Sunnah Safar prayer",
      "badge_supplications": "TRAVEL SUPPLICATIONS",
      "miqat_label": "MIQAT: The Boundary",
      "badge_ihram": "ENTERING THE STATE OF IHRAM",
      "p2_title": "PHASE 2: IHRAM AT THE MIQAT",
      "p2_desc": "Entering the state of Ihram. Men in two sheets, women in modest clothing.",
      "p3_title": "PHASE 3: ENTERING MASJID AL-HARAM",
      "p3_desc": "Enter with right foot and recite the Dua.",
      "talbiyah_box": "THE TALBIYAH: Repeatedly recite 'Labbayk Allahumma Labbayk...'",
      "kaaba_sight": "SIGHT OF THE KAABA: Upon first seeing the Kaaba, make sincere dua.",
      "badge_tawaf_rounds": "SEVEN ROUNDS COUNTER-CLOCKWISE",
      "p4_title": "PHASE 4: TAWAF (CIRCUMAMBULATION)",
      "p4_desc": "Seven rounds counter-clockwise starting at Black Stone.",
      "tawaf_prayer": "THE ESSENTIAL TAWAF PRAYER: Between Rukn Yamani and Black Stone...",
      "badge_saie_trips": "SEVEN TRIPS BETWEEN SAFA AND MARWAH",
      "p5_title": "PHASE 5: SA'IE (THE WALKING)",
      "p5_desc": "Seven trips between Safa and Marwah.",
      "green_lights": "THE GREEN LIGHTS: Men are encouraged to run/jog between the green lights.",
      "badge_shaving": "SHAVING OR TRIMMING THE HAIR",
      "p6_title": "PHASE 6: TAHALLUL (COMPLETION)",
      "p6_desc": "Shaving or trimming the hair to exit Ihram.",
      "tahallul_action": "Men may shave their heads (Halq) or trim (Taqsir)...",
      "completion_dua": "COMPLETION SUPPLICATION: O Allah, accept this from us...",
      "legend_rukun": "RUKUN - Mandatory Pillars (Golden border)",
      "legend_sunnah": "SUNNAH - Recommended Acts (Blue border)",
      "narration": "Welcome to your sacred journey of Umrah. This guide will lead you through six essential phases. We begin Phase 1 at home with purification and the Travel Dua: [ar]Bismillahi tawakkaltu 'ala Allah[/ar]. In Phase 2, you enter Ihram at the Miqat. Phase 3 brings you to the Masjid al-Haram where you recite the Talbiyah: [ar]Labbayk Allahumma Labbayk[/ar]. Phase 4 is the Tawaf, seven rounds around the Kaaba. Phase 5 is the Sa'ie between Safa and Marwah. Finally, Phase 6 is Tahallul, where you complete your journey by trimming your hair. May Allah accept your Umrah."
    },
    "ms": {
      "main_header": "Perjalanan Suci Anda:",
      "main_subheader": "Panduan Langkah demi Langkah Mengerjakan Umrah",
      "badge_purification": "PENYUCIAN ROHANI DAN JASMANI DI RUMAH",
      "dua_home": "DOA KELUAR RUMAH: Bismillah, tawakkaltu 'ala Allah...",
      "p1_title": "FASA 1: PERSEDIAAN & KEBERANGKATAN",
      "p1_ghusl": "Ghusl, Potong Kuku, Solat Sunat Safar",
      "check_ghusl": "Mandi Sunat",
      "check_nails": "Potong Kuku",
      "check_safar": "Solat Sunat Safar",
      "badge_supplications": "DOA-DOA DALAM PERJALANAN",
      "miqat_label": "MIQAT: Sempadan Niat",
      "badge_ihram": "MEMASUKI KEADAAN IHRAM",
      "p2_title": "FASA 2: IHRAM DI MIQAT",
      "p2_desc": "Memasuki keadaan Ihram. Lelaki dengan dua helai kain, wanita berpakaian sopan.",
      "p3_title": "FASA 3: MEMASUKI MASJIDIL HARAM",
      "p3_desc": "Masuk dengan kaki kanan dan baca doa.",
      "talbiyah_box": "TALBIYAH: Laungkan 'Labbayk Allahumma Labbayk...' berulang kali.",
      "kaaba_sight": "MELIHAT KAABAH: Berdoa dengan ikhlas saat pertama kali melihat Kaabah.",
      "badge_tawaf_rounds": "TUJUH PUSINGAN LAWAN JAM",
      "p4_title": "FASA 4: TAWAF (MENGELILINGI KAABAH)",
      "p4_desc": "Tujuh pusingan lawan jam bermula dari Hajarul Aswad.",
      "tawaf_prayer": "DOA TAWAF UTAMA: Antara Rukun Yamani dan Hajarul Aswad...",
      "badge_saie_trips": "TUJUH PERJALANAN ANTARA SAFA DAN MARWAH",
      "p5_title": "FASA 5: SA'IE (BERULANG-ALIK)",
      "p5_desc": "Tujuh perjalanan antara Safa dan Marwah.",
      "green_lights": "LAMPU HIJAU: Lelaki disunatkan berlari anak di antara lampu hijau.",
      "badge_shaving": "BERCUKUR ATAU BERGUNTING RAMBUT",
      "p6_title": "FASA 6: TAHALLUL (PENYELESAIAN)",
      "p6_desc": "Bercukur atau menggunting rambut untuk keluar dari Ihram.",
      "tahallul_action": "Lelaki boleh bercukur (Halq) atau bergunting (Taqsir)...",
      "completion_dua": "DOA PENYELESAIAN: Ya Allah, terimalah amalan kami...",
      "legend_rukun": "RUKUN - Wajib (Sempadan Emas)",
      "legend_sunnah": "SUNNAH - Digalakkan (Sempadan Biru)",
      "narration": "Selamat datang ke perjalanan suci Umrah anda. Panduan ini akan membawa anda melalui enam fasa penting. Kita mulakan Fasa 1 di rumah dengan penyucian dan Doa Musafir: [ar]Bismillahi tawakkaltu 'ala Allah[/ar]. Dalam Fasa 2, anda berniat Ihram di Miqat. Fasa 3 membawa anda ke Masjidil Haram di mana anda melaungkan Talbiyah: [ar]Labbayk Allahumma Labbayk[/ar]. Fasa 4 adalah Tawaf, tujuh pusingan mengelilingi Kaabah. Fasa 5 adalah Sa'ie antara Safa dan Marwah. Akhir sekali, Fasa 6 adalah Tahallul, di mana anda melengkapkan perjalanan dengan bergunting rambut. Semoga Allah menerima Umrah anda."
    },
    "ml": {
      "main_header": "നിങ്ങളുടെ വിശുദ്ധ യാത്ര:",
      "main_subheader": "ഉംറ നിർവ്വഹിക്കുന്നതിനുള്ള ഘട്ടം ഘട്ടമായുള്ള വഴികാട്ടി",
      "badge_purification": "വീട്ടിൽ നിന്നുള്ള ആത്മീയവും ശാരീരികവുമായ ശുദ്ധി",
      "dua_home": "വീട്ടിൽ നിന്ന് ഇറങ്ങുമ്പോഴുള്ള ദുആ...",
      "p1_title": "ഘട്ടം 1: തയ്യാറെടുപ്പും യാത്രയും",
      "p1_ghusl": "കുളി, നഖം വെട്ടൽ, സുന്നത്ത് സഫർ നിസ്കാരം",
      "check_ghusl": "കുളി",
      "check_nails": "നഖം വെട്ടൽ",
      "check_safar": "സുന്നത്ത് സഫർ നിസ്കാരം",
      "badge_supplications": "യാത്രാ പ്രാർത്ഥനകൾ",
      "miqat_label": "മീഖാത്ത്: അതിർത്തി",
      "badge_ihram": "ഇഹ്റാമിൽ പ്രവേശിക്കൽ",
      "p2_title": "ഘട്ടം 2: മീഖാത്തിൽ നിന്നുള്ള ഇഹ്റാം",
      "p2_desc": "ഇഹ്റാമിൽ പ്രവേശിക്കൽ. പുരുഷന്മാർക്ക് രണ്ട് തുണികൾ, സ്ത്രീകൾക്ക് മാന്യമായ വസ്ത്രം.",
      "p3_title": "ഘട്ടം 3: മസ്ജിദുൽ ഹറാമിൽ പ്രവേശിക്കൽ",
      "p3_desc": "വലതുകാൽ വെച്ച് പ്രവേശിക്കുക, ദുആ ചൊല്ലുക.",
      "talbiyah_box": "തൽബിയത്ത്: 'ലബ്ബൈക്ക് അല്ലാഹുമ്മ ലബ്ബൈക്ക്...' ചൊല്ലുക.",
      "kaaba_sight": "കഅബ കാണുമ്പോൾ: ആത്മാർത്ഥമായി ദുആ ചെയ്യുക.",
      "badge_tawaf_rounds": "ഇടത്തോട്ടുള്ള ഏഴ് പ്രദക്ഷിണങ്ങൾ",
      "p4_title": "ഘട്ടം 4: ത്വവാഫ് (പ്രദക്ഷിണം)",
      "p4_desc": "ഹജറുൽ അസ്‌വദ് മുതൽ ആരംഭിക്കുന്ന ഏഴ് പ്രദക്ഷിണങ്ങൾ.",
      "tawaf_prayer": "ത്വവാഫിലെ ദുആ: റുക്നുൽ യമാനിക്കും ഹജറുൽ അസ്‌വദിനും ഇടയിൽ...",
      "badge_saie_trips": "സഫയ്ക്കും മർവയ്ക്കും ഇടയിലുള്ള ഏഴ് നടത്തങ്ങൾ",
      "p5_title": "ഘട്ടം 5: സഅയ് (നടത്തം)",
      "p5_desc": "സഫയ്ക്കും മർവയ്ക്കും ഇടയിലുള്ള ഏഴ് നടത്തങ്ങൾ.",
      "green_lights": "പച്ച വിളക്കുകൾ: പുരുഷന്മാർ പച്ച വിളക്കുകൾക്കിടയിൽ വേഗത്തിൽ നടക്കുക.",
      "badge_shaving": "മുടി മുണ്ഡനം ചെയ്യുകയോ വെട്ടുകയോ ചെയ്യൽ",
      "p6_title": "ഘട്ടം 6: തഹല്ലുൽ (പൂർത്തീകരണം)",
      "p6_desc": "ഇഹ്റാമിൽ നിന്ന് ഒഴിവാകാൻ മുടി മുണ്ഡനം ചെയ്യുകയോ വെട്ടുകയോ ചെയ്യുക.",
      "tahallul_action": "പുരുഷന്മാർക്ക് തല മുണ്ഡനം ചെയ്യുകയോ മുടി വെട്ടുകയോ ചെയ്യാം...",
      "completion_dua": "പൂർത്തീകരണ പ്രാർത്ഥന: അല്ലാഹുവേ, ഞങ്ങളിൽ നിന്ന് ഇത് സ്വീകരിക്കേണമേ...",
      "legend_rukun": "അടിസ്ഥാന തൂണുകൾ (സുവർണ്ണ അതിർത്തി)",
      "legend_sunnah": "സുന്നത്ത് - ശുപാർശ ചെയ്തവ (നീല അതിർത്തി)"
    },
    "ta": {
      "main_header": "உங்கள் புனித பயணம்:",
      "main_subheader": "உம்ரா செய்வதற்கான படிப்படியான வழிகாட்டி",
      "badge_purification": "வீட்டில் ஆன்மீக மற்றும் உடல் ரீதியான தூய்மை",
      "dua_home": "வீட்டை விட்டு வெளியேறும்போது ஓதும் துஆ...",
      "p1_title": "கட்டம் 1: தயாரிப்பு & புறப்பாடு",
      "p1_ghusl": "குளித்தல், நகம் வெட்டுதல், சுன்னத் சஃபர் தொழுகை",
      "check_ghusl": "குளித்தல்",
      "check_nails": "நகம் வெட்டுதல்",
      "check_safar": "சுன்னத் சஃபர் தொழுகை",
      "badge_supplications": "பயண துஆக்கள்",
      "miqat_label": "மீகாத்: எல்லை",
      "badge_ihram": "இஹ்ராம் நிலையில் நுழைதல்",
      "p2_title": "கட்டம் 2: மீகாத்தில் இஹ்ராம்",
      "p2_desc": "இஹ்ராம் நிலையில் நுழைதல். ஆண்களுக்கு இரண்டு துணிகள், பெண்களுக்கு கண்ணியமான உடை.",
      "p3_title": "கட்டம் 3: மஸ்ஜிதுல் ஹராமிற்குள் நுழைதல்",
      "p3_desc": "வலது காலை வைத்து நுழைந்து துஆ ஓதவும்.",
      "talbiyah_box": "தல்பியா: 'லப்பைக் அல்லாஹும்ம லப்பைக்...' என்று கூறவும்.",
      "kaaba_sight": "கஃபாவைக் காணும்போது: உண்மையான துஆ செய்யவும்.",
      "badge_tawaf_rounds": "ஏழு சுற்றுக்கள் (இடஞ்சுழியாக)",
      "p4_title": "கட்டம் 4: தவாஃப் (சுற்றுதல்)",
      "p4_desc": "ஹஜருல் அஸ்வத் முதல் ஆரம்பிக்கும் ஏழு சுற்றுக்கள்.",
      "tawaf_prayer": "தவாஃப் துஆ: ருக்னுல் யமானிக்கும் ஹஜருல் அஸ்வதுக்கும் இடையில்...",
      "badge_saie_trips": "ஸஃபா மற்றும் மர்வா இடையே ஏழு முறை நடத்தல்",
      "p5_title": "கட்டம் 5: ஸயீ (நடத்தல்)",
      "p5_desc": "ஸஃபா மற்றும் மர்வா இடையே ஏழு முறை நடத்தல்.",
      "green_lights": "பச்சை விளக்குகள்: ஆண்கள் பச்சை விளக்குகளுக்கு இடையில் ஓடவும்.",
      "badge_shaving": "தலைமுடி மழித்தல் அல்லது கத்தரித்தல்",
      "p6_title": "கட்டம் 6: தஹல்லுல் (நிறைவு)",
      "p6_desc": "இஹ்ராம் நீங்க தலைமுடி மழித்தல் அல்லது கத்தரித்தல்.",
      "tahallul_action": "ஆண்கள் மொட்டை அடிக்கலாம் அல்லது முடியை வெட்டலாம்...",
      "completion_dua": "நிறைவு துஆ: யா அல்லாஹ், எங்களிடமிருந்து இதை ஏற்றுக்கொள்வாயாக...",
      "legend_rukun": "കടமையானவை (தங்க எல்லை)",
      "legend_sunnah": "சுன்னத் (நீல எல்லை)"
    }
