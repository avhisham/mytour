{
  "file_name": "doa1house.mp3",
  "subtitles": {
    "ar": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,605",
        "text": "بِسْمِ اللهِ"
      },
      {
        "start": "00:00:01,605",
        "end": "00:00:03,646",
        "text": "آمَنْتُ بِاللهِ"
      },
      {
        "start": "00:00:03,623",
        "end": "00:00:05,458",
        "text": "تَوَكَّلْتُ عَلَى اللهِ"
      },
      {
        "start": "00:00:05,435",
        "end": "00:00:08,737",
        "text": "وَ لَا حَوْلَ وَ لَا قُوَّةَ إِلَّا بِاللهِ"
      },
      {
        "start": "00:00:08,760",
        "end": "00:00:10,457",
        "text": "رَبِّ أَعُوذُ بِكَ"
      },
      {
        "start": "00:00:10,500",
        "end": "00:00:13,094",
        "text": "أَنْ أَضِلَّ أَوْ أُضَلَّ"
      },
      {
        "start": "00:00:13,117",
        "end": "00:00:15,365",
        "text": "أَوْ أَزِلَّ أَوْ أُزَلَّ"
      },
      {
        "start": "00:00:15,296",
        "end": "00:00:17,910",
        "text": "أَوْ أَظْلِمَ أَوْ أُظْلَمَ"
      },
      {
        "start": "00:00:17,887",
        "end": "00:00:21,052",
        "text": "أَوْ أَجْهَلَ أَوْ يُجْهَلَ"
      },
      {
        "start": "00:00:21,098",
        "end": "00:00:23,093",
        "text": "عَلَيَّ اللَّهُمَّ إِنِّي"
      },
      {
        "start": "00:00:23,093",
        "end": "00:00:24,813",
        "text": "لَمْ أَخْرُجْ أَشَرًا"
      },
      {
        "start": "00:00:24,836",
        "end": "00:00:26,189",
        "text": "وَ لَا بَطَرًا"
      },
      {
        "start": "00:00:26,189",
        "end": "00:00:29,308",
        "text": "وَ لَا رِيَاءً وَ لَا سُمْعَةً"
      },
      {
        "start": "00:00:29,354",
        "end": "00:00:29,927",
        "text": "بَلْ خَرَجْتُ"
      },
      {
        "start": "00:00:29,973",
        "end": "00:00:31,602",
        "text": "اتِّقَاءَ سَخَطِكَ"
      },
      {
        "start": "00:00:31,625",
        "end": "00:00:33,500",
        "text": "وَ قَضَاءَ فَرْضِكَ"
      },
      {
        "start": "00:00:33,500",
        "end": "00:00:35,775",
        "text": "وَ اتِّبَاعَ سُنَّةِ نَبِيِّكَ"
      },
      {
        "start": "00:00:35,775",
        "end": "00:00:39,000",
        "text": "وَ شَوْقًا إِلَى لِقَاءِكَ"
      }
    ],
    "tl": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,605",
        "text": "Bismillahi"
      },
      {
        "start": "00:00:01,605",
        "end": "00:00:03,646",
        "text": "amantu billahi"
      },
      {
        "start": "00:00:03,623",
        "end": "00:00:05,458",
        "text": "tawakkaltu 'alallahi"
      },
      {
        "start": "00:00:05,435",
        "end": "00:00:08,737",
        "text": "wa la hawla wa la quwwata illa billahi"
      },
      {
        "start": "00:00:08,760",
        "end": "00:00:10,457",
        "text": "rabbi a'udhu bika"
      },
      {
        "start": "00:00:10,500",
        "end": "00:00:13,094",
        "text": "an adilla aw udalla"
      },
      {
        "start": "00:00:13,117",
        "end": "00:00:15,365",
        "text": "aw azilla aw uzalla"
      },
      {
        "start": "00:00:15,296",
        "end": "00:00:17,910",
        "text": "aw azlima aw uzlama"
      },
      {
        "start": "00:00:17,887",
        "end": "00:00:21,052",
        "text": "aw ajhala aw yujhala"
      },
      {
        "start": "00:00:21,098",
        "end": "00:00:23,093",
        "text": "alayya Allahumma inni"
      },
      {
        "start": "00:00:23,093",
        "end": "00:00:24,813",
        "text": "lam akhruj asharan"
      },
      {
        "start": "00:00:24,836",
        "end": "00:00:26,189",
        "text": "wa la bataran"
      },
      {
        "start": "00:00:26,189",
        "end": "00:00:29,308",
        "text": "wa la riya'an wa la sum'atan"
      },
      {
        "start": "00:00:29,354",
        "end": "00:00:29,927",
        "text": "bal kharajtu"
      },
      {
        "start": "00:00:29,973",
        "end": "00:00:31,602",
        "text": "ittiqa'a sakhatika"
      },
      {
        "start": "00:00:31,625",
        "end": "00:00:33,500",
        "text": "wa qada'a fardika"
      },
      {
        "start": "00:00:33,500",
        "end": "00:00:35,775",
        "text": "wattiba'a sunnati nabiyyika"
      },
      {
        "start": "00:00:35,775",
        "end": "00:00:39,000",
        "text": "wa shawqan ila liqa'ika"
      }
    ],
    "ms": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,605",
        "text": "Dengan nama Allah"
      },
      {
        "start": "00:00:01,605",
        "end": "00:00:03,646",
        "text": "Aku beriman kepada Allah"
      },
      {
        "start": "00:00:03,623",
        "end": "00:00:05,458",
        "text": "Aku bertawakkal kepada Allah"
      },
      {
        "start": "00:00:05,435",
        "end": "00:00:08,737",
        "text": "Tiada daya dan kekuatan melainkan dengan Allah"
      },
      {
        "start": "00:00:08,760",
        "end": "00:00:10,457",
        "text": "Wahai Tuhanku, aku berlindung dengan-Mu"
      },
      {
        "start": "00:00:10,500",
        "end": "00:00:13,094",
        "text": "Daripada aku tersesat atau disesatkan"
      },
      {
        "start": "00:00:13,117",
        "end": "00:00:15,365",
        "text": "Atau aku tergelincir atau digelincirkan"
      },
      {
        "start": "00:00:15,296",
        "end": "00:00:17,910",
        "text": "Atau aku menzalimi atau dizalimi"
      },
      {
        "start": "00:00:17,887",
        "end": "00:00:21,052",
        "text": "Atau aku melakukan kebodohan atau diperlakukan bodoh"
      },
      {
        "start": "00:00:21,098",
        "end": "00:00:23,093",
        "text": "Ke atasku. Ya Allah sesungguhnya aku"
      },
      {
        "start": "00:00:23,093",
        "end": "00:00:24,813",
        "text": "Tidaklah aku keluar kerana sombong"
      },
      {
        "start": "00:00:24,836",
        "end": "00:00:26,189",
        "text": "Atau angkuh"
      },
      {
        "start": "00:00:26,189",
        "end": "00:00:29,308",
        "text": "Atau riyak atau mencari kemasyhuran"
      },
      {
        "start": "00:00:29,354",
        "end": "00:00:29,927",
        "text": "Bahkan aku keluar"
      },
      {
        "start": "00:00:29,973",
        "end": "00:00:31,602",
        "text": "Kerana takut akan kemurkaan-Mu"
      },
      {
        "start": "00:00:31,625",
        "end": "00:00:33,500",
        "text": "Dan menunaikan kewajipan-Mu"
      },
      {
        "start": "00:00:33,500",
        "end": "00:00:35,775",
        "text": "Dan mengikut sunnah Nabi-Mu"
      },
      {
        "start": "00:00:35,775",
        "end": "00:00:39,000",
        "text": "Serta rindu untuk menemui-Mu"
      }
    ],
    "en": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,605",
        "text": "In the name of Allah"
      },
      {
        "start": "00:00:01,605",
        "end": "00:00:03,646",
        "text": "I believe in Allah"
      },
      {
        "start": "00:00:03,623",
        "end": "00:00:05,458",
        "text": "I trust in Allah"
      },
      {
        "start": "00:00:05,435",
        "end": "00:00:08,737",
        "text": "There is no power nor might except with Allah"
      },
      {
        "start": "00:00:08,760",
        "end": "00:00:10,457",
        "text": "My Lord, I seek refuge in You"
      },
      {
        "start": "00:00:10,500",
        "end": "00:00:13,094",
        "text": "From straying or being led astray"
      },
      {
        "start": "00:00:13,117",
        "end": "00:00:15,365",
        "text": "From slipping or being made to slip"
      },
      {
        "start": "00:00:15,296",
        "end": "00:00:17,910",
        "text": "From oppressing or being oppressed"
      },
      {
        "start": "00:00:17,887",
        "end": "00:00:21,052",
        "text": "From being ignorant or being treated ignorantly"
      },
      {
        "start": "00:00:21,098",
        "end": "00:00:23,093",
        "text": "O Allah, indeed I"
      },
      {
        "start": "00:00:23,093",
        "end": "00:00:24,813",
        "text": "Did not go out for pride"
      },
      {
        "start": "00:00:24,836",
        "end": "00:00:26,189",
        "text": "Nor for arrogance"
      },
      {
        "start": "00:00:26,189",
        "end": "00:00:29,308",
        "text": "Nor for show or reputation"
      },
      {
        "start": "00:00:29,354",
        "end": "00:00:29,927",
        "text": "But I went out"
      },
      {
        "start": "00:00:29,973",
        "end": "00:00:31,602",
        "text": "To avoid Your wrath"
      },
      {
        "start": "00:00:31,625",
        "end": "00:00:33,500",
        "text": "And to fulfill Your obligation"
      },
      {
        "start": "00:00:33,500",
        "end": "00:00:35,775",
        "text": "And to follow the Sunnah of Your Prophet"
      },
      {
        "start": "00:00:35,775",
        "end": "00:00:39,000",
        "text": "And out of longing to meet You"
      }
    ],
    "ml": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,605",
        "text": "അല്ലാഹുവിന്റെ നാമത്തിൽ"
      },
      {
        "start": "00:00:01,605",
        "end": "00:00:03,646",
        "text": "ഞാൻ അല്ലാഹുവിൽ വിശ്വസിച്ചു"
      },
      {
        "start": "00:00:03,623",
        "end": "00:00:05,458",
        "text": "അല്ലാഹുവിൽ ഞാൻ ഭരമേൽപ്പിച്ചു"
      },
      {
        "start": "00:00:05,435",
        "end": "00:00:08,737",
        "text": "അല്ലാഹുവിനെക്കൊണ്ടല്ലാതെ യാതൊരു ശക്തിയുമില്ല"
      },
      {
        "start": "00:00:08,760",
        "end": "00:00:10,457",
        "text": "എന്റെ നാഥാ, ഞാൻ നിന്നോട് കാവൽ തേടുന്നു"
      },
      {
        "start": "00:00:10,500",
        "end": "00:00:13,094",
        "text": "ഞാൻ വഴിപിഴക്കുന്നതിൽ നിന്നോ പിഴപ്പിക്കപ്പെടുന്നതിൽ നിന്നോ"
      },
      {
        "start": "00:00:13,117",
        "end": "00:00:15,365",
        "text": "ഞാൻ തെന്നുന്നതിൽ നിന്നോ തെറ്റിക്കപ്പെടുന്നതിൽ നിന്നോ"
      },
      {
        "start": "00:00:15,296",
        "end": "00:00:17,910",
        "text": "ഞാൻ അക്രമിക്കുന്നതിൽ നിന്നോ അക്രമിക്കപ്പെടുന്നതിൽ നിന്നോ"
      },
      {
        "start": "00:00:17,887",
        "end": "00:00:21,052",
        "text": "ഞാൻ വിവരക്കേട് കാണിക്കുന്നതിൽ നിന്നോ എന്നോട് കാണിക്കപ്പെടുന്നതിൽ നിന്നോ"
      },
      {
        "start": "00:00:21,098",
        "end": "00:00:23,093",
        "text": "അല്ലാഹുവേ, തീർച്ചയായും ഞാൻ"
      },
      {
        "start": "00:00:23,093",
        "end": "00:00:24,813",
        "text": "അഹങ്കാരത്തോടെയോ ഗർവ്വോടെയോ അല്ല പുറപ്പെട്ടത്"
      },
      {
        "start": "00:00:24,836",
        "end": "00:00:26,189",
        "text": "ആരെയും കാണിക്കാനോ കേൾപ്പിക്കാനോ അല്ല"
      },
      {
        "start": "00:00:26,189",
        "end": "00:00:29,308",
        "text": "മറിച്ച് ഞാൻ പുറപ്പെട്ടത്"
      },
      {
        "start": "00:00:29,354",
        "end": "00:00:29,927",
        "text": "നിന്റെ കോപത്തെ ഭയന്നും"
      },
      {
        "start": "00:00:29,973",
        "end": "00:00:31,602",
        "text": "നിന്റെ നിർബന്ധ ബാധ്യത നിറവേറ്റാനും"
      },
      {
        "start": "00:00:31,625",
        "end": "00:00:33,500",
        "text": "നിന്റെ പ്രവാചകന്റെ ചര്യ പിന്തുടരാനും"
      },
      {
        "start": "00:00:33,500",
        "end": "00:00:35,775",
        "text": "നിന്നെ കാണാനുള്ള ആഗ്രഹം കൊണ്ടുമാണ്"
      },
      {
        "start": "00:00:35,775",
        "end": "00:00:39,000",
        "text": ""
      }
    ],
    "ta": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,605",
        "text": "அல்லாஹ்வின் பெயரால்"
      },
      {
        "start": "00:00:01,605",
        "end": "00:00:03,646",
        "text": "அல்லாஹ்வின் மீது நம்பிக்கை கொண்டேன்"
      },
      {
        "start": "00:00:03,623",
        "end": "00:00:05,458",
        "text": "அல்லாஹ்வின் மீதே முழுமையாகச் சார்ந்திருக்கிறேன்"
      },
      {
        "start": "00:00:05,435",
        "end": "00:00:08,737",
        "text": "அல்லாஹ்வின் உதவியின்றி மாற்றமோ ஆற்றலோ இல்லை"
      },
      {
        "start": "00:00:08,760",
        "end": "00:00:10,457",
        "text": "என் இறைவா, உன்னிடம் பாதுகாப்புத் தேடுகிறேன்"
      },
      {
        "start": "00:00:10,500",
        "end": "00:00:13,094",
        "text": "நான் வழிதவறுவதிலிருந்தோ வழிதவறச் செய்யப்படுவதிலிருந்தோ"
      },
      {
        "start": "00:00:13,117",
        "end": "00:00:15,365",
        "text": "நான் சறுக்குவதிலிருந்தோ சறுக்க வைக்கப்படுவதிலிருந்தோ"
      },
      {
        "start": "00:00:15,296",
        "end": "00:00:17,910",
        "text": "நான் அநியாயம் செய்வதிலிருந்தோ அநியாயம் செய்யப்படுவதிலிருந்தோ"
      },
      {
        "start": "00:00:17,887",
        "end": "00:00:21,052",
        "text": "நான் அறியாமையாக நடப்பதிலிருந்தோ என்னிடம் அவ்வாறு நடக்கப்படுவதிலிருந்தோ"
      },
      {
        "start": "00:00:21,098",
        "end": "00:00:23,093",
        "text": "யா அல்லாஹ், நிச்சயமாக நான்"
      },
      {
        "start": "00:00:23,093",
        "end": "00:00:24,813",
        "text": "பெருமைக் கொண்டு நான் புறப்படவில்லை"
      },
      {
        "start": "00:00:24,836",
        "end": "00:00:26,189",
        "text": "ஆணவத்துடனோ"
      },
      {
        "start": "00:00:26,189",
        "end": "00:00:29,308",
        "text": "பிறர் பார்க்கவோ பிறர் புகழவோ அல்ல"
      },
      {
        "start": "00:00:29,354",
        "end": "00:00:29,927",
        "text": "மாறாக நான் புறப்பட்டதெல்லாம்"
      },
      {
        "start": "00:00:29,973",
        "end": "00:00:31,602",
        "text": "உன் கோபத்தைப் பயந்தும்"
      },
      {
        "start": "00:00:31,625",
        "end": "00:00:33,500",
        "text": "உன் கடமையை நிறைவேற்றவும்"
      },
      {
        "start": "00:00:33,500",
        "end": "00:00:35,775",
        "text": "உன் நபியின் வழியைப் பின்பற்றவும்"
      },
      {
        "start": "00:00:35,775",
        "end": "00:00:39,000",
        "text": "உன்னைச் சந்திக்கும் ஆவலுடனும்"
      }
    ]
  }
}