{
  "file_name": "doa3haram.mp3",
  "subtitles": {
    "ar": [
      {
        "start": "00:00:00,000",
        "end": "00:00:02,500",
        "text": "اللَّهُمَّ إِنَّ هَذَا الْحَرَمَ حَرَمُكَ"
      },
      {
        "start": "00:00:02,500",
        "end": "00:00:04,500",
        "text": "وَالْبَلَدَ بَلَدُكَ"
      },
      {
        "start": "00:00:04,500",
        "end": "00:00:06,500",
        "text": "وَالْأَمْنَ أَمْنُكَ"
      },
      {
        "start": "00:00:06,500",
        "end": "00:00:09,500",
        "text": "فَحَرِّمْنِي عَلَى النَّارِ"
      },
      {
        "start": "00:00:09,500",
        "end": "00:00:15,000",
        "text": "وَآمِنِّي مِنْ عَذَابِكَ يَوْمَ تَبْعَثُ عِبَادَكَ"
      }
    ],
    "tl": [
      {
        "start": "00:00:00,000",
        "end": "00:00:02,500",
        "text": "Allahumma inna hadhal harama haramuka"
      },
      {
        "start": "00:00:02,500",
        "end": "00:00:04,500",
        "text": "wal balada baladuka"
      },
      {
        "start": "00:00:04,500",
        "end": "00:00:06,500",
        "text": "wal amna amnuka"
      },
      {
        "start": "00:00:06,500",
        "end": "00:00:09,500",
        "text": "fa harrimni 'alan-nar"
      },
      {
        "start": "00:00:09,500",
        "end": "00:01:15,000",
        "text": "wa aminni min 'adhabika yawma tab'athu 'ibadaka"
      }
    ],
    "ms": [
      {
        "start": "00:00:00,000",
        "end": "00:00:02,500",
        "text": "Ya Allah, sesungguhnya Tanah Haram ini adalah milik-Mu"
      },
      {
        "start": "00:00:02,500",
        "end": "00:00:04,500",
        "text": "Dan negeri ini adalah negeri-Mu"
      },
      {
        "start": "00:00:04,500",
        "end": "00:00:06,500",
        "text": "Dan keamanan ini adalah daripada-Mu"
      },
      {
        "start": "00:00:06,500",
        "end": "00:00:09,500",
        "text": "Maka haramkanlah aku daripada api neraka"
      },
      {
        "start": "00:00:09,500",
        "end": "00:01:15,000",
        "text": "Dan selamatkanlah aku daripada azab-Mu pada hari Engkau membangkitkan hamba-hamba-Mu"
      }
    ],
    "en": [
      {
        "start": "00:00:00,000",
        "end": "00:00:02,500",
        "text": "O Allah, indeed this Sanctuary is Your Sanctuary"
      },
      {
        "start": "00:00:02,500",
        "end": "00:00:04,500",
        "text": "And this city is Your city"
      },
      {
        "start": "00:00:04,500",
        "end": "00:00:06,500",
        "text": "And this safety is Your security"
      },
      {
        "start": "00:00:06,500",
        "end": "00:00:09,500",
        "text": "So forbid my flesh to the Fire"
      },
      {
        "start": "00:00:09,500",
        "end": "00:01:15,000",
        "text": "And protect me from Your punishment on the Day You resurrect Your servants"
      }
    ],
    "ml": [
      {
        "start": "00:00:00,000",
        "end": "00:00:02,500",
        "text": "അല്ലാഹുവേ, തീർച്ചയായും ഈ ഹറം നിന്റേതാണ്"
      },
      {
        "start": "00:00:02,500",
        "end": "00:00:04,500",
        "text": "ഈ നാടും നിന്റേതാണ്"
      },
      {
        "start": "00:00:04,500",
        "end": "00:00:06,500",
        "text": "ഈ സുരക്ഷിതത്വം നിന്റേതാണ്"
      },
      {
        "start": "00:00:06,500",
        "end": "00:00:09,500",
        "text": "അതുകൊണ്ട് എന്നെ നരകത്തിന് നിഷിദ്ധമാക്കേണമേ"
      },
      {
        "start": "00:00:09,500",
        "end": "00:01:15,000",
        "text": "നിന്റെ അടിമകളെ ഉയിർത്തെഴുന്നേൽപ്പിക്കുന്ന നാളിൽ നിന്റെ ശിക്ഷയിൽ നിന്ന് എനിക്ക് സംരക്ഷണം നൽകേണമേ"
      }
    ],
    "ta": [
      {
        "start": "00:00:00,000",
        "end": "00:00:02,500",
        "text": "யா அல்லாஹ், நிச்சயமாக இந்த ஹரம் உன்னுடைய ஹரம்"
      },
      {
        "start": "00:00:02,500",
        "end": "00:00:04,500",
        "text": "இந்த நகரம் உன்னுடைய நகரம்"
      },
      {
        "start": "00:00:04,500",
        "end": "00:00:06,500",
        "text": "இந்த அபயம் உன்னுடைய அபயம்"
      },
      {
        "start": "00:00:06,500",
        "end": "00:00:09,500",
        "text": "எனவே நரக நெருப்பை எனக்கு ஹராமாக்கி விடு"
      },
      {
        "start": "00:00:09,500",
        "end": "00:01:15,000",
        "text": "உன் அடியார்களை நீ எழுப்பும் நாளில் உன்னுடைய தண்டனையிலிருந்து எனக்கு பாதுகாப்பு அளிப்பாயாக"
      }
    ]
  }
}