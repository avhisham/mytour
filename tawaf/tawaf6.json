{
  "file_name": "tawaf6.mp3",
  "subtitles": {
    "ar": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,500",
        "text": "اللَّهُمَّ"
      },
      {
        "start": "00:00:01,500",
        "end": "00:00:02,959",
        "text": "إِنَّ لَكَ عَلَيَّ"
      },
      {
        "start": "00:00:02,931",
        "end": "00:00:04,673",
        "text": "حُقُوقًا كَثِيرَةً"
      },
      {
        "start": "00:00:04,646",
        "end": "00:00:06,941",
        "text": "فِيمَا بَيْنِي وَبَيْنَكَ"
      },
      {
        "start": "00:00:06,914",
        "end": "00:00:09,071",
        "text": "وَحُقُوقًا كَثِيرَةً"
      },
      {
        "start": "00:00:09,071",
        "end": "00:00:12,390",
        "text": "فِيمَا بَيْنِي وَبَيْنَ خَلْقِكَ"
      },
      {
        "start": "00:00:12,390",
        "end": "00:00:13,966",
        "text": "اللَّهُمَّ"
      },
      {
        "start": "00:00:13,966",
        "end": "00:00:15,736",
        "text": "مَا كَانَ لَكَ"
      },
      {
        "start": "00:00:15,791",
        "end": "00:00:18,087",
        "text": "فَاغْفِرْهُ لِي"
      },
      {
        "start": "00:00:18,087",
        "end": "00:00:20,521",
        "text": "وَمَا كَانَ لِخَلْقِكَ"
      },
      {
        "start": "00:00:20,548",
        "end": "00:00:23,010",
        "text": "فَتَحَمَّلْهُ عَنِّي"
      },
      {
        "start": "00:00:23,010",
        "end": "00:00:25,554",
        "text": "وَأَغْنِنِي بِحَلَالِكَ"
      },
      {
        "start": "00:00:25,554",
        "end": "00:00:27,490",
        "text": "عَنْ حَرَامِكَ"
      },
      {
        "start": "00:00:27,490",
        "end": "00:03:16,113",
        "text": "وَبِطَاعَتِكَ عَنْ مَعْصِيَتِكَ"
      },
      {
        "start": "00:00:31,611",
        "end": "00:00:34,847",
        "text": "وَبِفَضْلِكَ عَمَّنْ سِوَاكَ"
      },
      {
        "start": "00:00:34,847",
        "end": "00:00:37,500",
        "text": "يَا وَاسِعَ الْمَغْفِرَةِ"
      },
      {
        "start": "00:00:37,500",
        "end": "00:00:39,687",
        "text": "وَأَنْتَ يَا اللهُ"
      },
      {
        "start": "00:00:39,714",
        "end": "00:00:43,558",
        "text": "حَلِيمٌ كَرِيمٌ عَظِيمٌ"
      },
      {
        "start": "00:00:43,558",
        "end": "00:00:45,716",
        "text": "تُحِبُّ الْعَفْوَ"
      },
      {
        "start": "00:00:45,688",
        "end": "00:00:47,000",
        "text": "فَاعْفُ عَنِّي"
      }
    ],
    "tl": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,500",
        "text": "Allahumma"
      },
      {
        "start": "00:00:01,500",
        "end": "00:00:02,959",
        "text": "inna laka 'alayya"
      },
      {
        "start": "00:00:02,931",
        "end": "00:00:04,673",
        "text": "huquqan kathiratan"
      },
      {
        "start": "00:00:04,646",
        "end": "00:00:06,941",
        "text": "fima bayni wa baynaka"
      },
      {
        "start": "00:00:06,914",
        "end": "00:00:09,071",
        "text": "wa huquqan kathiratan"
      },
      {
        "start": "00:00:09,071",
        "end": "00:00:12,390",
        "text": "fima bayni wa bayna khalqika"
      },
      {
        "start": "00:00:12,390",
        "end": "00:00:13,966",
        "text": "Allahumma"
      },
      {
        "start": "00:00:13,966",
        "end": "00:00:15,736",
        "text": "ma kana laka"
      },
      {
        "start": "00:00:15,791",
        "end": "00:00:18,087",
        "text": "faghfirhu li"
      },
      {
        "start": "00:00:18,087",
        "end": "00:00:20,521",
        "text": "wa ma kana likhalqika"
      },
      {
        "start": "00:00:20,548",
        "end": "00:00:23,010",
        "text": "fatahammalhu 'anni"
      },
      {
        "start": "00:00:23,010",
        "end": "00:00:25,554",
        "text": "wa aghnini bi halalika"
      },
      {
        "start": "00:00:25,554",
        "end": "00:00:27,490",
        "text": "'an haramika"
      },
      {
        "start": "00:00:27,490",
        "end": "00:03:16,113",
        "text": "wa bita'atika 'an ma'siyatika"
      },
      {
        "start": "00:00:31,611",
        "end": "00:00:34,847",
        "text": "wa bifadhlika 'amman siwaka"
      },
      {
        "start": "00:00:34,847",
        "end": "00:00:37,500",
        "text": "ya wasi'al maghfirah"
      },
      {
        "start": "00:00:37,500",
        "end": "00:00:39,687",
        "text": "wa anta ya Allah"
      },
      {
        "start": "00:00:39,714",
        "end": "00:00:43,558",
        "text": "halimun karimun 'azhimun"
      },
      {
        "start": "00:00:43,558",
        "end": "00:00:45,716",
        "text": "tuhibbul 'afwa"
      },
      {
        "start": "00:00:45,688",
        "end": "00:00:47,000",
        "text": "fa'fu 'anni"
      }
    ],
    "ms": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,500",
        "text": "Ya Allah"
      },
      {
        "start": "00:00:01,500",
        "end": "00:00:02,959",
        "text": "Sesungguhnya Engkau mempunyai"
      },
      {
        "start": "00:00:02,931",
        "end": "00:00:04,673",
        "text": "Hak-hak yang banyak ke atasku"
      },
      {
        "start": "00:00:04,646",
        "end": "00:00:06,941",
        "text": "Dalam hubungan antara aku dengan-Mu"
      },
      {
        "start": "00:00:06,914",
        "end": "00:00:09,071",
        "text": "Dan hak-hak yang banyak"
      },
      {
        "start": "00:00:09,071",
        "end": "00:00:12,390",
        "text": "Dalam hubungan antara aku dengan makhluk-Mu"
      },
      {
        "start": "00:00:12,390",
        "end": "00:00:13,966",
        "text": "Ya Allah"
      },
      {
        "start": "00:00:13,966",
        "end": "00:00:15,736",
        "text": "Apa yang menjadi hak-Mu"
      },
      {
        "start": "00:00:15,791",
        "end": "00:00:18,087",
        "text": "Maka ampunkanlah bagiku"
      },
      {
        "start": "00:00:18,087",
        "end": "00:00:20,521",
        "text": "Dan apa yang menjadi hak makhluk-Mu"
      },
      {
        "start": "00:00:20,548",
        "end": "00:00:23,010",
        "text": "Maka tanggunglah ia dariku"
      },
      {
        "start": "00:00:23,010",
        "end": "00:00:25,554",
        "text": "Dan kayakanlah aku dengan rezeki yang halal"
      },
      {
        "start": "00:00:25,554",
        "end": "00:00:27,490",
        "text": "Daripada yang haram"
      },
      {
        "start": "00:00:27,490",
        "end": "00:03:16,113",
        "text": "Dan dengan ketaatan kepada-Mu daripada maksiat"
      },
      {
        "start": "00:00:31,611",
        "end": "00:00:34,847",
        "text": "Dan dengan kurniaan-Mu daripada selain-Mu"
      },
      {
        "start": "00:00:34,847",
        "end": "00:00:37,500",
        "text": "Wahai Tuhan Yang Maha Luas pengampunan-Nya"
      },
      {
        "start": "00:00:37,500",
        "end": "00:00:39,687",
        "text": "Dan Engkau ya Allah"
      },
      {
        "start": "00:00:39,714",
        "end": "00:00:43,558",
        "text": "Maha Penyantun, Maha Pemurah lagi Maha Agung"
      },
      {
        "start": "00:00:43,558",
        "end": "00:00:45,716",
        "text": "Engkau sukakan kemaafan"
      },
      {
        "start": "00:00:45,688",
        "end": "00:00:47,000",
        "text": "Maka maafkanlah aku"
      }
    ],
    "en": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,500",
        "text": "O Allah"
      },
      {
        "start": "00:00:01,500",
        "end": "00:00:02,959",
        "text": "Indeed, You have over me"
      },
      {
        "start": "00:00:02,931",
        "end": "00:00:04,673",
        "text": "Many rights"
      },
      {
        "start": "00:00:04,646",
        "end": "00:00:06,941",
        "text": "Between me and You"
      },
      {
        "start": "00:00:06,914",
        "end": "00:00:09,071",
        "text": "And many rights"
      },
      {
        "start": "00:00:09,071",
        "end": "00:00:12,390",
        "text": "Between me and Your creation"
      },
      {
        "start": "00:00:12,390",
        "end": "00:00:13,966",
        "text": "O Allah"
      },
      {
        "start": "00:00:13,966",
        "end": "00:00:15,736",
        "text": "Whatever is for You"
      },
      {
        "start": "00:00:15,791",
        "end": "00:00:18,087",
        "text": "Forgive it for me"
      },
      {
        "start": "00:00:18,087",
        "end": "00:00:20,521",
        "text": "And whatever is for Your creation"
      },
      {
        "start": "00:00:20,548",
        "end": "00:00:23,010",
        "text": "Bear it on my behalf"
      },
      {
        "start": "00:00:23,010",
        "end": "00:00:25,554",
        "text": "And enrich me with Your lawful provision"
      },
      {
        "start": "00:00:25,554",
        "end": "00:00:27,490",
        "text": "Instead of Your unlawful"
      },
      {
        "start": "00:00:27,490",
        "end": "00:03:16,113",
        "text": "And with Your obedience instead of Your disobedience"
      },
      {
        "start": "00:00:31,611",
        "end": "00:00:34,847",
        "text": "And with Your grace instead of anyone besides You"
      },
      {
        "start": "00:00:34,847",
        "end": "00:00:37,500",
        "text": "O Most Vast in Forgiveness"
      },
      {
        "start": "00:00:37,500",
        "end": "00:00:39,687",
        "text": "And You, O Allah"
      },
      {
        "start": "00:00:39,714",
        "end": "00:00:43,558",
        "text": "Are Most Clement, Generous, and Great"
      },
      {
        "start": "00:00:43,558",
        "end": "00:00:45,716",
        "text": "You love to forgive"
      },
      {
        "start": "00:00:45,688",
        "end": "00:00:47,000",
        "text": "So forgive me"
      }
    ],
    "ml": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,500",
        "text": "അല്ലാഹുവേ"
      },
      {
        "start": "00:00:01,500",
        "end": "00:00:02,959",
        "text": "നിനക്ക് എന്റെ മേൽ ഉണ്ട്"
      },
      {
        "start": "00:00:02,931",
        "end": "00:00:04,673",
        "text": "ധാരാളം അവകാശങ്ങൾ"
      },
      {
        "start": "00:00:04,646",
        "end": "00:00:06,941",
        "text": "എനിക്കും നിനക്കും ഇടയിലുള്ള കാര്യങ്ങളിൽ"
      },
      {
        "start": "00:00:06,914",
        "end": "00:00:09,071",
        "text": "ധാരാളം അവകാശങ്ങൾ"
      },
      {
        "start": "00:00:09,071",
        "end": "00:00:12,390",
        "text": "എനിക്കും നിന്റെ സൃഷ്ടികൾക്കും ഇടയിലുള്ള കാര്യങ്ങളിൽ"
      },
      {
        "start": "00:00:12,390",
        "end": "00:00:13,966",
        "text": "അല്ലാഹുവേ"
      },
      {
        "start": "00:00:13,966",
        "end": "00:00:15,736",
        "text": "നിനക്കുള്ള അവകാശങ്ങൾ"
      },
      {
        "start": "00:00:15,791",
        "end": "00:00:18,087",
        "text": "അതുകൊണ്ട് എനിക്ക് പൊറുത്തു തരേണമേ"
      },
      {
        "start": "00:00:18,087",
        "end": "00:00:20,521",
        "text": "നിന്റെ സൃഷ്ടികൾക്കുള്ള അവകാശങ്ങൾ"
      },
      {
        "start": "00:00:20,548",
        "end": "00:00:23,010",
        "text": "അത് എനിക്ക് വേണ്ടി നീ ഏറ്റെടുക്കേണമേ"
      },
      {
        "start": "00:00:23,010",
        "end": "00:00:25,554",
        "text": "ഹലാലായ വിഭവങ്ങൾ കൊണ്ട് എന്നെ ധന്യനാക്കേണമേ"
      },
      {
        "start": "00:00:25,554",
        "end": "00:00:27,490",
        "text": "ഹറാമായവയിൽ നിന്ന് (എന്നെ തടഞ്ഞുകൊണ്ട്)"
      },
      {
        "start": "00:00:27,490",
        "end": "00:03:16,113",
        "text": "നിന്റെ അനുസരണത്തിൽ എന്നെ ധന്യനാക്കേണമേ, പാപങ്ങളിൽ നിന്ന് (തടഞ്ഞുകൊണ്ട്)"
      },
      {
        "start": "00:00:31,611",
        "end": "00:00:34,847",
        "text": "നിന്റെ അനുഗ്രഹം കൊണ്ട് മറ്റാരെക്കാളും എന്നെ ധന്യനാക്കേണമേ"
      },
      {
        "start": "00:00:34,847",
        "end": "00:00:37,500",
        "text": "പാപമോചനത്തിൽ വിശാലതയുള്ളവനേ"
      },
      {
        "start": "00:00:37,500",
        "end": "00:00:39,687",
        "text": "നീയാകുന്നു അല്ലാഹുവേ"
      },
      {
        "start": "00:00:39,714",
        "end": "00:00:43,558",
        "text": "ക്ഷമാശീലനും ഔദാര്യമുള്ളവനും മഹാനും"
      },
      {
        "start": "00:00:43,558",
        "end": "00:00:45,716",
        "text": "നീ മാപ്പിനെ ഇഷ്ടപ്പെടുന്നു"
      },
      {
        "start": "00:00:45,688",
        "end": "00:00:47,000",
        "text": "അതുകൊണ്ട് എനിക്ക് മാപ്പ് നൽകേണമേ"
      }
    ],
    "ta": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,500",
        "text": "யா அல்லாஹ்"
      },
      {
        "start": "00:00:01,500",
        "end": "00:00:02,959",
        "text": "நிச்சயமாக உனக்கு என் மீது"
      },
      {
        "start": "00:00:02,931",
        "end": "00:00:04,673",
        "text": "ஏராளமான கடமைகள் உள்ளன"
      },
      {
        "start": "00:00:04,646",
        "end": "00:00:06,941",
        "text": "எனக்கும் உனக்கும் இடையில் உள்ளவற்றில்"
      },
      {
        "start": "00:00:06,914",
        "end": "00:00:09,071",
        "text": "ஏராளமான கடமைகள் உள்ளன"
      },
      {
        "start": "00:00:09,071",
        "end": "00:00:12,390",
        "text": "எனக்கும் உன் படைப்புகளுக்கும் இடையில் உள்ளவற்றில்"
      },
      {
        "start": "00:00:12,390",
        "end": "00:00:13,966",
        "text": "யா அல்லாஹ்"
      },
      {
        "start": "00:00:13,966",
        "end": "00:00:15,736",
        "text": "உனக்குரிய கடமைகளை"
      },
      {
        "start": "00:00:15,791",
        "end": "00:00:18,087",
        "text": "எனக்காக மன்னித்துவிடு"
      },
      {
        "start": "00:00:18,087",
        "end": "00:00:20,521",
        "text": "உன் படைப்புகளுக்குரிய கடமைகளை"
      },
      {
        "start": "00:00:20,548",
        "end": "00:00:23,010",
        "text": "எனக்காக நீ பொறுப்பேற்றுக்கொள்"
      },
      {
        "start": "00:00:23,010",
        "end": "00:00:25,554",
        "text": "உன் ஹலாலான விபரங்களைக் கொண்டு என்னைப் போதுமாக்கிக் கொள்"
      },
      {
        "start": "00:00:25,554",
        "end": "00:00:27,490",
        "text": "ஹராமானவற்றை விட்டும்"
      },
      {
        "start": "00:00:27,490",
        "end": "00:03:16,113",
        "text": "உன் வழிபாட்டைக் கொண்டு உன் மாறுபாட்டை விட்டும்"
      },
      {
        "start": "00:00:31,611",
        "end": "00:00:34,847",
        "text": "உன் அருளைக் கொண்டு உன்னைத் தவிர மற்றவர்களை விட்டும்"
      },
      {
        "start": "00:00:34,847",
        "end": "00:00:37,500",
        "text": "மன்னிப்பில் விசாலமானவனே"
      },
      {
        "start": "00:00:37,500",
        "end": "00:00:39,687",
        "text": "மேலும் நீயோ யா அல்லாஹ்"
      },
      {
        "start": "00:00:39,714",
        "end": "00:00:43,558",
        "text": "மிகவும் சகிப்புத்தன்மை உடையவன், கண்ணியமானவன், மகத்துவமானவன்"
      },
      {
        "start": "00:00:43,558",
        "end": "00:00:45,716",
        "text": "நீ மன்னிப்பை விரும்புகிறாய்"
      },
      {
        "start": "00:00:45,688",
        "end": "00:00:47,000",
        "text": "எனவே என்னை மன்னித்துவிடு"
      }
    ]
  }
}