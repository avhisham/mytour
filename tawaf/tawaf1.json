{
  "file_name": "tawaf1.mp3",
  "subtitles": {
    "ar": [
      {
        "start": "00:00:00,000",
        "end": "00:00:02,803",
        "text": "سُبْحَانَ اللهِ وَالْحَمْدُ للهِ"
      },
      {
        "start": "00:00:02,803",
        "end": "00:00:06,920",
        "text": "وَلَا إِلَهَ إِلَّا اللهُ وَاللهُ أَكْبَرُ"
      },
      {
        "start": "00:00:06,920",
        "end": "00:00:12,351",
        "text": "وَلَا حَوْلَ وَلَا قُوَّةَ إِلَّا بِاللَّهِ الْعَلِيِّ الْعَظِيمِ"
      },
      {
        "start": "00:00:12,438",
        "end": "00:00:18,263",
        "text": "وَالصَّلَاةُ وَالسَّلَامُ عَلَى رَسُولِ اللهِ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ"
      },
      {
        "start": "00:00:18,263",
        "end": "00:00:22,074",
        "text": "اللَّهُمَّ إِيمَانًا بِكَ"
      },
      {
        "start": "00:00:22,074",
        "end": "00:00:24,395",
        "text": "وَتَصْدِيقًا بِكِتَابِكَ"
      },
      {
        "start": "00:00:24,351",
        "end": "00:00:26,629",
        "text": "وَوَفَاءً بِعَهْدِكَ"
      },
      {
        "start": "00:00:26,629",
        "end": "00:00:30,702",
        "text": "وَاتِّبَاعًا لِسُنَّةِ نَبِيِّكَ مُحَمَّدٍ"
      },
      {
        "start": "00:00:30,702",
        "end": "00:00:33,505",
        "text": "صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ"
      },
      {
        "start": "00:00:33,505",
        "end": "00:00:38,060",
        "text": "اللَّهُمَّ إِنِّي أَسْأَلُكَ الْعَفْوَ وَالْعَافِيَةَ"
      },
      {
        "start": "00:00:38,060",
        "end": "00:00:42,527",
        "text": "وَالْمُعَافَاةَ الدَّائِمَةَ فِي الدِّينِ وَالدُّنْيَا وَالْآخِرَةِ"
      },
      {
        "start": "00:00:42,527",
        "end": "00:00:44,761",
        "text": "وَالْفَوْزَ بِالْجَنَّةِ"
      },
      {
        "start": "00:00:44,761",
        "end": "00:00:46,907",
        "text": "وَالنَّجَاةَ مِنَ النَّارِ"
      }
    ],
    "tl": [
      {
        "start": "00:00:00,000",
        "end": "00:00:02,803",
        "text": "Subhanallahi wal hamdu lillah"
      },
      {
        "start": "00:00:02,803",
        "end": "00:00:06,920",
        "text": "wa la ilaha illallahu wallahu akbar"
      },
      {
        "start": "00:00:06,920",
        "end": "00:00:12,351",
        "text": "wa la hawla wa la quwwata illa billahil 'aliyyil 'adheem"
      },
      {
        "start": "00:00:12,438",
        "end": "00:00:18,263",
        "text": "was-salatu was-salamu 'ala rasulillahi sallallahu 'alayhi wa sallam"
      },
      {
        "start": "00:00:18,263",
        "end": "00:00:22,074",
        "text": "Allahumma imanan bika"
      },
      {
        "start": "00:00:22,074",
        "end": "00:00:24,395",
        "text": "wa tasdiqan bi kitabika"
      },
      {
        "start": "00:00:24,351",
        "end": "00:00:26,629",
        "text": "wa wafa'an bi 'ahdika"
      },
      {
        "start": "00:00:26,629",
        "end": "00:00:30,702",
        "text": "wattiba'an li-sunnati nabiyyika Muhammadin"
      },
      {
        "start": "00:00:30,702",
        "end": "00:00:33,505",
        "text": "sallallahu 'alayhi wa sallam"
      },
      {
        "start": "00:00:33,505",
        "end": "00:00:38,060",
        "text": "Allahumma inni as'alukal 'afwa wal 'afiyah"
      },
      {
        "start": "00:00:38,060",
        "end": "00:00:42,527",
        "text": "wal mu'afatad-da'imata fid-dini wad-dunya wal akhirah"
      },
      {
        "start": "00:00:42,527",
        "end": "00:00:44,761",
        "text": "wal fawza bil jannah"
      },
      {
        "start": "00:00:44,761",
        "end": "00:00:46,907",
        "text": "wan-najata minan-nar"
      }
    ],
    "ms": [
      {
        "start": "00:00:00,000",
        "end": "00:00:02,803",
        "text": "Maha Suci Allah dan segala puji bagi Allah"
      },
      {
        "start": "00:00:02,803",
        "end": "00:00:06,920",
        "text": "Tiada Tuhan melainkan Allah dan Allah Maha Besar"
      },
      {
        "start": "00:00:06,920",
        "end": "00:00:12,351",
        "text": "Tiada daya dan kekuatan melainkan dengan pertolongan Allah Yang Maha Tinggi lagi Maha Agung"
      },
      {
        "start": "00:00:12,438",
        "end": "00:00:18,263",
        "text": "Selawat dan salam ke atas Rasulullah SAW"
      },
      {
        "start": "00:00:18,263",
        "end": "00:00:22,074",
        "text": "Ya Allah, hamba beriman kepada-Mu"
      },
      {
        "start": "00:00:22,074",
        "end": "00:00:24,395",
        "text": "Dan membenarkan kitab-Mu"
      },
      {
        "start": "00:00:24,351",
        "end": "00:00:26,629",
        "text": "Dan memenuhi janji-Mu"
      },
      {
        "start": "00:00:26,629",
        "end": "00:00:30,702",
        "text": "Dan mengikut sunnah Nabi-Mu, Muhammad"
      },
      {
        "start": "00:00:30,702",
        "end": "00:00:33,505",
        "text": "Selawat Allah ke atasnya dan salam"
      },
      {
        "start": "00:00:33,505",
        "end": "00:00:38,060",
        "text": "Ya Allah, sesungguhnya hamba memohon kepada-Mu keampunan dan kesejahteraan"
      },
      {
        "start": "00:00:38,060",
        "end": "00:00:42,527",
        "text": "Serta perlindungan yang berterusan dalam agama, dunia dan akhirat"
      },
      {
        "start": "00:00:42,527",
        "end": "00:00:44,761",
        "text": "Dan kemenangan mendapat syurga"
      },
      {
        "start": "00:00:44,761",
        "end": "00:00:46,907",
        "text": "Serta keselamatan daripada api neraka"
      }
    ],
    "en": [
      {
        "start": "00:00:00,000",
        "end": "00:00:02,803",
        "text": "Glory be to Allah, and all praise is to Allah"
      },
      {
        "start": "00:00:02,803",
        "end": "00:00:06,920",
        "text": "There is no god but Allah, and Allah is Greatest"
      },
      {
        "start": "00:00:06,920",
        "end": "00:00:12,351",
        "text": "There is no power nor might except with Allah, the Most High, the Supreme"
      },
      {
        "start": "00:00:12,438",
        "end": "00:00:18,263",
        "text": "Blessings and peace be upon the Messenger of Allah, peace be upon him"
      },
      {
        "start": "00:00:18,263",
        "end": "00:00:22,074",
        "text": "O Allah, out of faith in You"
      },
      {
        "start": "00:00:22,074",
        "end": "00:00:24,395",
        "text": "And in belief of Your Book"
      },
      {
        "start": "00:00:24,351",
        "end": "00:00:26,629",
        "text": "And in fulfillment of Your covenant"
      },
      {
        "start": "00:00:26,629",
        "end": "00:00:30,702",
        "text": "And in following the Sunnah of Your Prophet, Muhammad"
      },
      {
        "start": "00:00:30,702",
        "end": "00:00:33,505",
        "text": "May Allah's peace and blessings be upon him"
      },
      {
        "start": "00:00:33,505",
        "end": "00:00:38,060",
        "text": "O Allah, I ask You for forgiveness and well-being"
      },
      {
        "start": "00:00:38,060",
        "end": "00:00:42,527",
        "text": "And permanent protection in my religion, worldly life, and the Hereafter"
      },
      {
        "start": "00:00:42,527",
        "end": "00:00:44,761",
        "text": "And the attainment of Paradise"
      },
      {
        "start": "00:00:44,761",
        "end": "00:00:46,907",
        "text": "And salvation from the Fire"
      }
    ],
    "ml": [
      {
        "start": "00:00:00,000",
        "end": "00:00:02,803",
        "text": "അല്ലാഹു എത്ര പരിശുദ്ധൻ, സർവ്വ സ്തുതിയും അല്ലാഹുവിനാണ്"
      },
      {
        "start": "00:00:02,803",
        "end": "00:00:06,920",
        "text": "അല്ലാഹുവല്ലാതെ മറ്റാരാധ്യനില്ല, അല്ലാഹു ഏറ്റവും വലിയവനാണ്"
      },
      {
        "start": "00:00:06,920",
        "end": "00:00:12,351",
        "text": "പരമോന്നതനും മഹാനുമായ അല്ലാഹുവിനെക്കൊണ്ടല്ലാതെ യാതൊരു കഴിവും കരുത്തുമില്ല"
      },
      {
        "start": "00:00:12,438",
        "end": "00:00:18,263",
        "text": "അല്ലാഹുവിന്റെ ദൂതന്റെ മേൽ അല്ലാഹുവിന്റെ രക്ഷയും സമാധാനവും ഉണ്ടാകട്ടെ"
      },
      {
        "start": "00:00:18,263",
        "end": "00:00:22,074",
        "text": "അല്ലാഹുവേ, നിന്നിൽ വിശ്വസിച്ചുകൊണ്ടും"
      },
      {
        "start": "00:00:22,074",
        "end": "00:00:24,395",
        "text": "നിന്റെ ഗ്രന്ഥത്തെ സത്യപ്പെടുത്തിയുകൊണ്ടും"
      },
      {
        "start": "00:00:24,351",
        "end": "00:00:26,629",
        "text": "നിന്നോടുള്ള കരാർ പാലിച്ചുകൊണ്ടും"
      },
      {
        "start": "00:00:26,629",
        "end": "00:00:30,702",
        "text": "നിന്റെ പ്രവാചകൻ മുഹമ്മദ് നബിയുടെ ചര്യ പിന്തുടർന്നുകൊണ്ടും"
      },
      {
        "start": "00:00:30,702",
        "end": "00:00:33,505",
        "text": "അവിടുത്തെ മേൽ അല്ലാഹുവിന്റെ രക്ഷയും സമാധാനവും ഉണ്ടാകട്ടെ"
      },
      {
        "start": "00:00:33,505",
        "end": "00:00:38,060",
        "text": "അല്ലാഹുവേ, നിന്നോട് ഞാൻ പാപമോചനവും സൗഖ്യവും തേടുന്നു"
      },
      {
        "start": "00:00:38,060",
        "end": "00:00:42,527",
        "text": "ദീനിലും ദുനിയാവിലും ആഖിറത്തിലും ശാശ്വതമായ മോക്ഷം ഞാൻ നിന്നോട് അപേക്ഷിക്കുന്നു"
      },
      {
        "start": "00:00:42,527",
        "end": "00:00:44,761",
        "text": "സ്വർഗ്ഗലബ്ധിക്കായി ഞാൻ പ്രാർത്ഥിക്കുന്നു"
      },
      {
        "start": "00:00:44,761",
        "end": "00:00:46,907",
        "text": "നരകശിക്ഷയിൽ നിന്നുള്ള രക്ഷയും (ഞാൻ തേടുന്നു)"
      }
    ],
    "ta": [
      {
        "start": "00:00:00,000",
        "end": "00:00:02,803",
        "text": "அல்லாஹ் தூய்மையானவன், புகழனைத்தும் அல்லாஹ்வுக்கே உரியது"
      },
      {
        "start": "00:00:02,803",
        "end": "00:00:06,920",
        "text": "அல்லாஹ்வைத் தவிர வேறு இறைவனில்லை, அல்லாஹ்வே மிகப் பெரியவன்"
      },
      {
        "start": "00:00:06,920",
        "end": "00:00:12,351",
        "text": "கண்ணியமிக்கவனும் மகத்துவமிக்கவனுமான அல்லாஹ்வின் உதவியின்றி மாற்றமோ ஆற்றலோ இல்லை"
      },
      {
        "start": "00:00:12,438",
        "end": "00:00:18,263",
        "text": "அல்லாஹ்வின் தூதர் மீது ஸலவாத்தும் ஸலாமும் உண்டாகட்டும்"
      },
      {
        "start": "00:00:18,263",
        "end": "00:00:22,074",
        "text": "யா அல்லாஹ்! உன் மீது நம்பிக்கை கொண்டு"
      },
      {
        "start": "00:00:22,074",
        "end": "00:00:24,395",
        "text": "உன் வேதத்தை உண்மைப்படுத்தி"
      },
      {
        "start": "00:00:24,351",
        "end": "00:00:26,629",
        "text": "உன்னுடைய உடன்படிக்கையை நிறைவேற்றி"
      },
      {
        "start": "00:00:26,629",
        "end": "00:00:30,702",
        "text": "உன் நபியாகிய முஹம்மது (ஸல்) அவர்களின் வழிமுறையைப் பின்பற்றி"
      },
      {
        "start": "00:00:30,702",
        "end": "00:00:33,505",
        "text": "அல்லாஹ்வின் அருளும் சாந்தியும் அவர் மீது உண்டாகட்டும்"
      },
      {
        "start": "00:00:33,505",
        "end": "00:00:38,060",
        "text": "யா அல்லாஹ்! உன்னிடம் மன்னிப்பையும் ஆரோக்கியத்தையும் வேண்டுகிறேன்"
      },
      {
        "start": "00:00:38,060",
        "end": "00:00:42,527",
        "text": "மார்க்கத்திலும், உலக வாழ்விலும், மறுமையிலும் நிலையான பாதுகாப்பை வேண்டுகிறேன்"
      },
      {
        "start": "00:00:42,527",
        "end": "00:00:44,761",
        "text": "மேலும் சுவனத்தின் வெற்றியை (வேண்டுகிறேன்)"
      },
      {
        "start": "00:00:44,761",
        "end": "00:00:46,907",
        "text": "நரக நெருப்பிலிருந்து பாதுகாப்பையும் (வேண்டுகிறேன்)"
      }
    ]
  }
}