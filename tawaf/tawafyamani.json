{
  "file_name": "tawafyamani.mp3",
  "subtitles": {
    "ar": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,448",
        "text": "بِسْمِ اللهِ"
      },
      {
        "start": "00:00:01,448",
        "end": "00:00:03,217",
        "text": "اللهُ أَكْبَرُ"
      },
      {
        "start": "00:00:03,217",
        "end": "00:00:04,067",
        "text": "اللَّهُمَّ"
      },
      {
        "start": "00:00:04,025",
        "end": "00:00:05,808",
        "text": "رَبَّنَا آتِنَا"
      },
      {
        "start": "00:00:05,850",
        "end": "00:00:07,772",
        "text": "فِي الدُّنْيَا حَسَنَةً"
      },
      {
        "start": "00:00:07,772",
        "end": "00:00:10,042",
        "text": "وَفِي الْآخِرَةِ حَسَنَةً"
      },
      {
        "start": "00:00:10,042",
        "end": "00:00:12,605",
        "text": "وَقِنَا عَذَابَ النَّارِ"
      },
      {
        "start": "00:00:12,605",
        "end": "00:00:14,569",
        "text": "وَأَدْخِلْنَا الْجَنَّةَ"
      },
      {
        "start": "00:00:14,569",
        "end": "00:00:16,673",
        "text": "مَعَ الْأَبْرَارِ"
      },
      {
        "start": "00:00:16,673",
        "end": "00:00:18,511",
        "text": "يَا عَزِيزُ يَا غَفَّارُ"
      },
      {
        "start": "00:00:18,511",
        "end": "00:00:22,676",
        "text": "يَا رَبَّ الْعَالَمِينَ"
      }
    ],
    "tl": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,448",
        "text": "Bismillahi"
      },
      {
        "start": "00:00:01,448",
        "end": "00:00:03,217",
        "text": "Allahu akbar"
      },
      {
        "start": "00:00:03,217",
        "end": "00:00:04,067",
        "text": "Allahumma"
      },
      {
        "start": "00:00:04,025",
        "end": "00:00:05,808",
        "text": "rabbana atina"
      },
      {
        "start": "00:00:05,850",
        "end": "00:00:07,772",
        "text": "fid-dunya hasanatan"
      },
      {
        "start": "00:00:07,772",
        "end": "00:00:10,042",
        "text": "wa fil-akhirati hasanatan"
      },
      {
        "start": "00:00:10,042",
        "end": "00:00:12,605",
        "text": "wa qina 'adhaban-nar"
      },
      {
        "start": "00:00:12,605",
        "end": "00:00:14,569",
        "text": "wa adkhilnal-jannata"
      },
      {
        "start": "00:00:14,569",
        "end": "00:00:16,673",
        "text": "ma'al-abrar"
      },
      {
        "start": "00:00:16,673",
        "end": "00:00:18,511",
        "text": "ya 'azizu ya ghaffar"
      },
      {
        "start": "00:00:18,511",
        "end": "00:00:22,676",
        "text": "ya rabbal-'alamin"
      }
    ],
    "ms": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,448",
        "text": "Dengan nama Allah"
      },
      {
        "start": "00:00:01,448",
        "end": "00:00:03,217",
        "text": "Allah Maha Besar"
      },
      {
        "start": "00:00:03,217",
        "end": "00:00:04,067",
        "text": "Ya Allah"
      },
      {
        "start": "00:00:04,025",
        "end": "00:00:05,808",
        "text": "Wahai Tuhan kami, kurniakanlah kami"
      },
      {
        "start": "00:00:05,850",
        "end": "00:00:07,772",
        "text": "Kebaikan di dunia"
      },
      {
        "start": "00:00:07,772",
        "end": "00:00:10,042",
        "text": "Dan kebaikan di akhirat"
      },
      {
        "start": "00:00:10,042",
        "end": "00:00:12,605",
        "text": "Dan peliharalah kami dari azab neraka"
      },
      {
        "start": "00:00:12,605",
        "end": "00:00:14,569",
        "text": "Dan masukkanlah kami ke dalam syurga"
      },
      {
        "start": "00:00:14,569",
        "end": "00:00:16,673",
        "text": "Bersama orang-orang yang berbakti"
      },
      {
        "start": "00:00:16,673",
        "end": "00:00:18,511",
        "text": "Wahai Tuhan Yang Maha Perkasa lagi Maha Pengampun"
      },
      {
        "start": "00:00:18,511",
        "end": "00:00:22,676",
        "text": "Wahai Tuhan semesta alam"
      }
    ],
    "en": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,448",
        "text": "In the name of Allah"
      },
      {
        "start": "00:00:01,448",
        "end": "00:00:03,217",
        "text": "Allah is Greatest"
      },
      {
        "start": "00:00:03,217",
        "end": "00:00:04,067",
        "text": "O Allah"
      },
      {
        "start": "00:00:04,025",
        "end": "00:00:05,808",
        "text": "Our Lord, grant us"
      },
      {
        "start": "00:00:05,850",
        "end": "00:00:07,772",
        "text": "Good in this world"
      },
      {
        "start": "00:00:07,772",
        "end": "00:00:10,042",
        "text": "And good in the Hereafter"
      },
      {
        "start": "00:00:10,042",
        "end": "00:00:12,605",
        "text": "And protect us from the punishment of the Fire"
      },
      {
        "start": "00:00:12,605",
        "end": "00:00:14,569",
        "text": "And admit us into Paradise"
      },
      {
        "start": "00:00:14,569",
        "end": "00:00:16,673",
        "text": "With the righteous"
      },
      {
        "start": "00:00:16,673",
        "end": "00:00:18,511",
        "text": "O Mighty, O Forgiving"
      },
      {
        "start": "00:00:18,511",
        "end": "00:00:22,676",
        "text": "O Lord of the worlds"
      }
    ],
    "ml": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,448",
        "text": "അല്ലാഹുവിന്റെ നാമത്തിൽ"
      },
      {
        "start": "00:00:01,448",
        "end": "00:00:03,217",
        "text": "അല്ലാഹു ഏറ്റവും വലിയവനാണ്"
      },
      {
        "start": "00:00:03,217",
        "end": "00:00:04,067",
        "text": "അല്ലാഹുവേ"
      },
      {
        "start": "00:00:04,025",
        "end": "00:00:05,808",
        "text": "ഞങ്ങളുടെ നാഥാ, ഞങ്ങൾക്ക് നൽകേണമേ"
      },
      {
        "start": "00:00:05,850",
        "end": "00:00:07,772",
        "text": "ദുനിയാവിൽ നന്മ"
      },
      {
        "start": "00:00:07,772",
        "end": "00:00:10,042",
        "text": "ആഖിറത്തിലും നന്മ"
      },
      {
        "start": "00:00:10,042",
        "end": "00:00:12,605",
        "text": "നരകശിക്ഷയിൽ നിന്ന് ഞങ്ങളെ കാക്കേണമേ"
      },
      {
        "start": "00:00:12,605",
        "end": "00:00:14,569",
        "text": "ഞങ്ങളെ സ്വർഗ്ഗത്തിൽ പ്രവേശിപ്പിക്കേണമേ"
      },
      {
        "start": "00:00:14,569",
        "end": "00:00:16,673",
        "text": "പുണ്യവാന്മാരോടൊപ്പം"
      },
      {
        "start": "00:00:16,673",
        "end": "00:00:18,511",
        "text": "പ്രതാപിയും പൊറുക്കുന്നവനുമായവനേ"
      },
      {
        "start": "00:00:18,511",
        "end": "00:00:22,676",
        "text": "ലോകരക്ഷിതാവേ"
      }
    ],
    "ta": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,448",
        "text": "அல்லாஹ்வின் பெயரால்"
      },
      {
        "start": "00:00:01,448",
        "end": "00:00:03,217",
        "text": "அல்லாஹ் மிகப் பெரியவன்"
      },
      {
        "start": "00:00:03,217",
        "end": "00:00:04,067",
        "text": "யா அல்லாஹ்"
      },
      {
        "start": "00:00:04,025",
        "end": "00:00:05,808",
        "text": "எங்கள் இறைவா, எங்களுக்கு வழங்குவாயாக"
      },
      {
        "start": "00:00:05,850",
        "end": "00:00:07,772",
        "text": "இம்மையிலும் நன்மையை"
      },
      {
        "start": "00:00:07,772",
        "end": "00:00:10,042",
        "text": "மறுமையிலும் நன்மையை"
      },
      {
        "start": "00:00:10,042",
        "end": "00:12,605",
        "text": "நரக நெருப்பிலிருந்து எங்களைக் காப்பாயாக"
      },
      {
        "start": "00:00:12,605",
        "end": "00:00:14,569",
        "text": "எங்களைச் சுவனத்தில் நுழைப்பாயாக"
      },
      {
        "start": "00:00:14,569",
        "end": "00:00:16,673",
        "text": "நல்லவர்களுடன் சேர்த்து"
      },
      {
        "start": "00:00:16,673",
        "end": "00:00:18,511",
        "text": "கண்ணியமிக்கவனே மன்னிப்பவனே"
      },
      {
        "start": "00:00:18,511",
        "end": "00:00:22,676",
        "text": "அகிலங்களின் இறைவனே"
      }
    ]
  }
}