{
  "file_name": "tawaf4.mp3",
  "subtitles": {
    "ar": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,112",
        "text": "اللَّهُمَّ"
      },
      {
        "start": "00:00:01,022",
        "end": "00:00:02,646",
        "text": "اجْعَلْ هَذِهِ الْعُمْرَةَ"
      },
      {
        "start": "00:00:02,677",
        "end": "00:00:04,211",
        "text": "عُمْرَةً مَقْبُولَةً"
      },
      {
        "start": "00:00:04,271",
        "end": "00:00:06,406",
        "text": "وَسَعْيًا مَشْكُورًا"
      },
      {
        "start": "00:00:06,406",
        "end": "00:00:08,061",
        "text": "وَذَنْبًا مَغْفُورًا"
      },
      {
        "start": "00:00:08,211",
        "end": "00:00:10,527",
        "text": "وَعَمَلًا صَالِحًا مَقْبُولًا"
      },
      {
        "start": "00:00:10,497",
        "end": "00:00:12,663",
        "text": "وَتِجَارَةً لَنْ تَبُورَ"
      },
      {
        "start": "00:00:12,663",
        "end": "00:00:15,851",
        "text": "يَا عَالِمَ مَا فِي الصُّدُورِ"
      },
      {
        "start": "00:00:15,851",
        "end": "00:00:18,137",
        "text": "أَخْرِجْنِي يَا اللهُ"
      },
      {
        "start": "00:00:18,137",
        "end": "00:00:20,664",
        "text": "مِنَ الظُّلُمَاتِ إِلَى النُّورِ"
      },
      {
        "start": "00:00:20,634",
        "end": "00:00:22,439",
        "text": "اللَّهُمَّ"
      },
      {
        "start": "00:00:22,439",
        "end": "00:00:23,943",
        "text": "إِنِّي أَسْأَلُكَ"
      },
      {
        "start": "00:00:23,943",
        "end": "00:00:25,657",
        "text": "مُوجِبَاتِ رَحْمَتِكَ"
      },
      {
        "start": "00:00:25,657",
        "end": "00:00:28,003",
        "text": "وَعَزَائِمَ مَغْفِرَتِكَ"
      },
      {
        "start": "00:00:27,943",
        "end": "00:00:30,590",
        "text": "وَالسَّلَامَةَ مِنْ كُلِّ إِثْمٍ"
      },
      {
        "start": "00:00:30,560",
        "end": "00:00:33,358",
        "text": "وَالْغَنِيمَةَ مِنْ كُلِّ بِرٍّ"
      },
      {
        "start": "00:00:33,328",
        "end": "00:00:35,463",
        "text": "وَالْفَوْزَ بِالْجَنَّةِ"
      },
      {
        "start": "00:00:35,433",
        "end": "00:00:37,689",
        "text": "وَالنَّجَاةَ مِنَ النَّارِ"
      },
      {
        "start": "00:00:37,809",
        "end": "00:00:41,269",
        "text": "رَبِّ قَنِّعْنِي بِمَا رَزَقْتَنِي"
      },
      {
        "start": "00:00:41,238",
        "end": "00:00:44,547",
        "text": "وَبَارِكْ لِي فِيمَا أَعْطَيْتَنِي"
      },
      {
        "start": "00:00:44,457",
        "end": "00:00:46,111",
        "text": "وَاخْلُفْ عَلَيَّ"
      },
      {
        "start": "00:00:46,051",
        "end": "00:00:47,796",
        "text": "كُلَّ غَائِبَةٍ لِي"
      },
      {
        "start": "00:00:47,766",
        "end": "00:00:49,119",
        "text": "مِنْكَ بِخَيْرٍ"
      }
    ],
    "tl": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,112",
        "text": "Allahumma"
      },
      {
        "start": "00:00:01,022",
        "end": "00:00:02,646",
        "text": "ij'al hadhihil 'umrata"
      },
      {
        "start": "00:00:02,677",
        "end": "00:00:04,211",
        "text": "'umratan maqbulatan"
      },
      {
        "start": "00:00:04,271",
        "end": "00:00:06,406",
        "text": "wa sa'yan mashkuran"
      },
      {
        "start": "00:00:06,406",
        "end": "00:00:08,061",
        "text": "wa dhanban maghfuran"
      },
      {
        "start": "00:00:08,211",
        "end": "00:00:10,527",
        "text": "wa 'amalan salihan maqbulan"
      },
      {
        "start": "00:00:10,497",
        "end": "00:00:12,663",
        "text": "wa tijaratan lan tabur"
      },
      {
        "start": "00:00:12,663",
        "end": "00:00:15,851",
        "text": "ya 'alima ma fis-sudur"
      },
      {
        "start": "00:00:15,851",
        "end": "00:00:18,137",
        "text": "akhrijni ya Allah"
      },
      {
        "start": "00:00:18,137",
        "end": "00:00:20,664",
        "text": "minaz-zulumati ilan-nur"
      },
      {
        "start": "00:00:20,634",
        "end": "00:00:22,439",
        "text": "Allahumma"
      },
      {
        "start": "00:00:22,439",
        "end": "00:00:23,943",
        "text": "inni as'aluka"
      },
      {
        "start": "00:00:23,943",
        "end": "00:00:25,657",
        "text": "mujibati rahmatika"
      },
      {
        "start": "00:00:25,657",
        "end": "00:00:28,003",
        "text": "wa 'azaima maghfiratika"
      },
      {
        "start": "00:00:27,943",
        "end": "00:00:30,590",
        "text": "was-salamata min kulli ithm"
      },
      {
        "start": "00:00:30,560",
        "end": "00:00:33,358",
        "text": "wal-ghanimata min kulli birr"
      },
      {
        "start": "00:00:33,328",
        "end": "00:00:35,463",
        "text": "wal-fawza bil-jannah"
      },
      {
        "start": "00:00:35,433",
        "end": "00:00:37,689",
        "text": "wan-najata minan-nar"
      },
      {
        "start": "00:00:37,809",
        "end": "00:00:41,269",
        "text": "rabbi qanni'ni bima razaqtani"
      },
      {
        "start": "00:00:41,238",
        "end": "00:00:44,547",
        "text": "wa barik li fima a'taytani"
      },
      {
        "start": "00:00:44,457",
        "end": "00:00:46,111",
        "text": "wakhluf 'alayya"
      },
      {
        "start": "00:00:46,051",
        "end": "00:00:47,796",
        "text": "kulla gha'ibatin li"
      },
      {
        "start": "00:00:47,766",
        "end": "00:00:49,119",
        "text": "minka bikhayr"
      }
    ],
    "ms": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,112",
        "text": "Ya Allah"
      },
      {
        "start": "00:00:01,022",
        "end": "00:00:02,646",
        "text": "Jadikanlah umrah ini"
      },
      {
        "start": "00:00:02,677",
        "end": "00:00:04,211",
        "text": "Umrah yang mabrur"
      },
      {
        "start": "00:00:04,271",
        "end": "00:00:06,406",
        "text": "Dan usaha yang diterima"
      },
      {
        "start": "00:00:06,406",
        "end": "00:00:08,061",
        "text": "Dan dosa yang diampunkan"
      },
      {
        "start": "00:00:08,211",
        "end": "00:00:10,527",
        "text": "Dan amal soleh yang maqbul"
      },
      {
        "start": "00:00:10,497",
        "end": "00:00:12,663",
        "text": "Dan perdagangan yang tidak akan rugi"
      },
      {
        "start": "00:00:12,663",
        "end": "00:00:15,851",
        "text": "Wahai Tuhan yang mengetahui isi hati"
      },
      {
        "start": "00:00:15,851",
        "end": "00:00:18,137",
        "text": "Keluarkanlah aku ya Allah"
      },
      {
        "start": "00:00:18,137",
        "end": "00:00:20,664",
        "text": "Dari kegelapan kepada cahaya"
      },
      {
        "start": "00:00:20,634",
        "end": "00:00:22,439",
        "text": "Ya Allah"
      },
      {
        "start": "00:00:22,439",
        "end": "00:00:23,943",
        "text": "Sesungguhnya aku memohon kepada-Mu"
      },
      {
        "start": "00:00:23,943",
        "end": "00:00:25,657",
        "text": "Rahmat yang mewajibkan syurga"
      },
      {
        "start": "00:00:25,657",
        "end": "00:00:28,003",
        "text": "Dan keampunan yang pasti"
      },
      {
        "start": "00:00:27,943",
        "end": "00:00:30,590",
        "text": "Dan terpelihara dari segala dosa"
      },
      {
        "start": "00:00:30,560",
        "end": "00:00:33,358",
        "text": "Dan beroleh segala kebaikan"
      },
      {
        "start": "00:00:33,328",
        "end": "00:00:35,463",
        "text": "Dan kemenangan mendapat syurga"
      },
      {
        "start": "00:00:35,433",
        "end": "00:00:37,689",
        "text": "Dan terselamat dari api neraka"
      },
      {
        "start": "00:00:37,809",
        "end": "00:00:41,269",
        "text": "Wahai Tuhanku, jadikanlah aku merasa cukup dengan rezeki yang Engkau berikan"
      },
      {
        "start": "00:00:41,238",
        "end": "00:00:44,547",
        "text": "Dan berkatilah aku pada apa yang Engkau kurniakan"
      },
      {
        "start": "00:00:44,457",
        "end": "00:00:46,111",
        "text": "Dan gantikanlah bagiku"
      },
      {
        "start": "00:00:46,051",
        "end": "00:00:47,796",
        "text": "Segala yang hilang dariku"
      },
      {
        "start": "00:00:47,766",
        "end": "00:00:49,119",
        "text": "Dengan kebaikan daripada-Mu"
      }
    ],
    "en": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,112",
        "text": "O Allah"
      },
      {
        "start": "00:00:01,022",
        "end": "00:00:02,646",
        "text": "Make this Umrah"
      },
      {
        "start": "00:00:02,677",
        "end": "00:00:04,211",
        "text": "An accepted Umrah"
      },
      {
        "start": "00:00:04,271",
        "end": "00:00:06,406",
        "text": "And a recognized effort"
      },
      {
        "start": "00:00:06,406",
        "end": "00:00:08,061",
        "text": "And a forgiven sin"
      },
      {
        "start": "00:00:08,211",
        "end": "00:00:10,527",
        "text": "And an accepted righteous deed"
      },
      {
        "start": "00:00:10,497",
        "end": "00:00:12,663",
        "text": "And a trade that will never perish"
      },
      {
        "start": "00:00:12,663",
        "end": "00:00:15,851",
        "text": "O Knower of what is in the hearts"
      },
      {
        "start": "00:00:15,851",
        "end": "00:00:18,137",
        "text": "Bring me out, O Allah"
      },
      {
        "start": "00:00:18,137",
        "end": "00:00:20,664",
        "text": "From darkness into light"
      },
      {
        "start": "00:00:20,634",
        "end": "00:00:22,439",
        "text": "O Allah"
      },
      {
        "start": "00:00:22,439",
        "end": "00:00:23,943",
        "text": "I ask You for"
      },
      {
        "start": "00:00:23,943",
        "end": "00:00:25,657",
        "text": "The causes of Your mercy"
      },
      {
        "start": "00:00:25,657",
        "end": "00:00:28,003",
        "text": "And the certainty of Your forgiveness"
      },
      {
        "start": "00:00:27,943",
        "end": "00:00:30,590",
        "text": "And safety from every sin"
      },
      {
        "start": "00:00:30,560",
        "end": "00:00:33,358",
        "text": "And the gain of every virtue"
      },
      {
        "start": "00:00:33,328",
        "end": "00:00:35,463",
        "text": "And the victory of Paradise"
      },
      {
        "start": "00:00:35,433",
        "end": "00:00:37,689",
        "text": "And salvation from the Fire"
      },
      {
        "start": "00:00:37,809",
        "end": "00:00:41,269",
        "text": "My Lord, make me content with what You have provided me"
      },
      {
        "start": "00:00:41,238",
        "end": "00:00:44,547",
        "text": "And bless me in what You have given me"
      },
      {
        "start": "00:00:44,457",
        "end": "00:00:46,111",
        "text": "And replace for me"
      },
      {
        "start": "00:00:46,051",
        "end": "00:00:47,796",
        "text": "Everything I have lost"
      },
      {
        "start": "00:00:47,766",
        "end": "00:00:49,119",
        "text": "With good from You"
      }
    ],
    "ml": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,112",
        "text": "അല്ലാഹുവേ"
      },
      {
        "start": "00:00:01,022",
        "end": "00:00:02,646",
        "text": "ഈ ഉംറയെ നീ ആക്കേണമേ"
      },
      {
        "start": "00:00:02,677",
        "end": "00:00:04,211",
        "text": "സ്വീകരിക്കപ്പെട്ട ഉംറ"
      },
      {
        "start": "00:00:04,271",
        "end": "00:00:06,406",
        "text": "നന്ദി അറിയിക്കപ്പെട്ട പരിശ്രമം"
      },
      {
        "start": "00:00:06,406",
        "end": "00:00:08,061",
        "text": "പൊറുക്കപ്പെട്ട പാപം"
      },
      {
        "start": "00:00:08,211",
        "end": "00:00:10,527",
        "text": "സ്വീകരിക്കപ്പെട്ട സൽക്കർമ്മം"
      },
      {
        "start": "00:00:10,497",
        "end": "00:00:12,663",
        "text": "ഒരിക്കലും നഷ്ടപ്പെടാത്ത കച്ചവടം"
      },
      {
        "start": "00:00:12,663",
        "end": "00:00:15,851",
        "text": "ഹൃദയങ്ങളിലുള്ളത് അറിയുന്നവനേ"
      },
      {
        "start": "00:00:15,851",
        "end": "00:00:18,137",
        "text": "എന്നെ നീ പുറത്തുകൊണ്ടുവരേണമേ"
      },
      {
        "start": "00:00:18,137",
        "end": "00:00:20,664",
        "text": "ഇരുളുകളിൽ നിന്നും വെളിച്ചത്തിലേക്ക്"
      },
      {
        "start": "00:00:20,634",
        "end": "00:00:22,439",
        "text": "അല്ലാഹുവേ"
      },
      {
        "start": "00:00:22,439",
        "end": "00:00:23,943",
        "text": "ഞാൻ നിന്നോട് ചോദിക്കുന്നു"
      },
      {
        "start": "00:00:23,943",
        "end": "00:00:25,657",
        "text": "നിന്റെ കാരുണ്യത്തിന് കാരണമാകുന്നവ"
      },
      {
        "start": "00:00:25,657",
        "end": "00:00:28,003",
        "text": "നിന്റെ പാപമോചനത്തിനുള്ള ഉറപ്പുകൾ"
      },
      {
        "start": "00:00:27,943",
        "end": "00:00:30,590",
        "text": "എല്ലാ പാപങ്ങളിൽ നിന്നുമുള്ള സുരക്ഷ"
      },
      {
        "start": "00:00:30,560",
        "end": "00:00:33,358",
        "text": "എല്ലാ പുണ്യപ്രവൃത്തികളുടെയും നേട്ടം"
      },
      {
        "start": "00:00:33,328",
        "end": "00:00:35,463",
        "text": "സ്വർഗ്ഗലബ്ധിയായ വിജയം"
      },
      {
        "start": "00:00:35,433",
        "end": "00:00:37,689",
        "text": "നരകത്തിൽ നിന്നുള്ള രക്ഷ"
      },
      {
        "start": "00:00:37,809",
        "end": "00:00:41,269",
        "text": "എന്റെ നാഥാ, നീ എനിക്ക് നൽകിയതിൽ എന്നെ സംതൃപ്തനാക്കേണമേ"
      },
      {
        "start": "00:00:41,238",
        "end": "00:00:44,547",
        "text": "നീ എനിക്ക് നൽകിയതിൽ അനുഗ്രഹം നൽകേണമേ"
      },
      {
        "start": "00:00:44,457",
        "end": "00:00:46,111",
        "text": "എനിക്ക് പകരമായി നൽകേണമേ"
      },
      {
        "start": "00:00:46,051",
        "end": "00:00:47,796",
        "text": "എനിക്ക് നഷ്ടപ്പെട്ടവയ്ക്കെല്ലാം"
      },
      {
        "start": "00:00:47,766",
        "end": "00:00:49,119",
        "text": "നിന്നിൽ നിന്നുള്ള നന്മ കൊണ്ട്"
      }
    ],
    "ta": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,112",
        "text": "யா அல்லாஹ்"
      },
      {
        "start": "00:00:01,022",
        "end": "00:00:02,646",
        "text": "இந்த உம்ராவை ஆக்குவாயாக"
      },
      {
        "start": "00:00:02,677",
        "end": "00:00:04,211",
        "text": "ஒப்புக்கொள்ளப்பட்ட உம்ராவாக"
      },
      {
        "start": "00:00:04,271",
        "end": "00:00:06,406",
        "text": "நன்றி கூறப்பட்ட முயற்சியாக"
      },
      {
        "start": "00:00:06,406",
        "end": "00:00:08,061",
        "text": "மன்னிக்கப்பட்ட பாவமாக"
      },
      {
        "start": "00:00:08,211",
        "end": "00:00:10,527",
        "text": "ஏற்கப்பட்ட நற்செயலாக"
      },
      {
        "start": "00:00:10,497",
        "end": "00:00:12,663",
        "text": "அழிவற்ற வியாபாரமாக"
      },
      {
        "start": "00:00:12,663",
        "end": "00:00:15,851",
        "text": "உள்ளங்களில் உள்ளதை அறிபவனே"
      },
      {
        "start": "00:00:15,851",
        "end": "00:00:18,137",
        "text": "என்னை வெளியேற்றுவாயாக யா அல்லாஹ்"
      },
      {
        "start": "00:00:18,137",
        "end": "00:00:20,664",
        "text": "இருள்களிலிருந்து ஒளியின் பக்கம்"
      },
      {
        "start": "00:00:20,634",
        "end": "00:00:22,439",
        "text": "யா அல்லாஹ்"
      },
      {
        "start": "00:00:22,439",
        "end": "00:00:23,943",
        "text": "நிச்சயமாக நான் உன்னிடம் கேட்கிறேன்"
      },
      {
        "start": "00:00:23,943",
        "end": "00:00:25,657",
        "text": "உன் அருளைப் பெற்றுத் தருபவை"
      },
      {
        "start": "00:00:25,657",
        "end": "00:00:28,003",
        "text": "உன் மன்னிப்பை உறுதி செய்பவை"
      },
      {
        "start": "00:00:27,943",
        "end": "00:00:30,590",
        "text": "ஒவ்வொரு பாவத்திலிருந்தும் பாதுகாப்பு"
      },
      {
        "start": "00:00:30,560",
        "end": "00:00:33,358",
        "text": "ஒவ்வொரு நன்மையின் பலன்"
      },
      {
        "start": "00:00:33,328",
        "end": "00:00:35,463",
        "text": "சுவனத்தின் வெற்றி"
      },
      {
        "start": "00:00:35,433",
        "end": "00:00:37,689",
        "text": "நரகத்திலிருந்து விடுதலை"
      },
      {
        "start": "00:00:37,809",
        "end": "00:00:41,269",
        "text": "என் இறைவா, நீ எனக்கு வழங்கியதைக் கொண்டு என்னைத் திருப்திப்படுத்து"
      },
      {
        "start": "00:00:41,238",
        "end": "00:00:44,547",
        "text": "நீ எனக்குக் கொடுத்தவற்றில் பரகத் செய்"
      },
      {
        "start": "00:00:44,457",
        "end": "00:00:46,111",
        "text": "எனக்குப் பகரமாகத் தருவாயாக"
      },
      {
        "start": "00:00:46,051",
        "end": "00:00:47,796",
        "text": "எனக்குத் தவறிப்போன எல்லாவற்றிற்கும்"
      },
      {
        "start": "00:00:47,766",
        "end": "00:00:49,119",
        "text": "உன்னிடமிருந்து சிறந்த நன்மையைக் கொண்டு"
      }
    ]
  }
}