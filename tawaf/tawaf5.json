{
  "file_name": "tawaf5.mp3",
  "subtitles": {
    "ar": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,165",
        "text": "اللَّهُمَّ"
      },
      {
        "start": "00:00:01,165",
        "end": "00:00:03,284",
        "text": "أَظِلَّنِي تَحْتَ ظِلِّ عَرْشِكَ"
      },
      {
        "start": "00:00:03,284",
        "end": "00:00:06,322",
        "text": "يَوْمَ لَا ظِلَّ إِلَّا ظِلُّكَ"
      },
      {
        "start": "00:00:06,322",
        "end": "00:00:09,148",
        "text": "وَلَا بَاقِيَ إِلَّا وَجْهُكَ"
      },
      {
        "start": "00:00:09,148",
        "end": "00:00:11,938",
        "text": "وَاسْقِنِي مِنْ حَوْضِ نَبِيِّكَ"
      },
      {
        "start": "00:00:11,867",
        "end": "00:00:15,541",
        "text": "مُحَمَّدٍ صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ"
      },
      {
        "start": "00:00:15,576",
        "end": "00:00:17,837",
        "text": "شَرْبَةً هَنِيئَةً"
      },
      {
        "start": "00:00:17,801",
        "end": "00:00:20,592",
        "text": "لَا نَظْمَأُ بَعْدَهَا أَبَدًا"
      },
      {
        "start": "00:00:20,627",
        "end": "00:00:21,581",
        "text": "اللَّهُمَّ"
      },
      {
        "start": "00:00:21,546",
        "end": "00:00:23,135",
        "text": "إِنِّي أَسْأَلُكَ"
      },
      {
        "start": "00:00:23,064",
        "end": "00:00:25,078",
        "text": "مِنْ خَيْرِ مَا سَأَلَكَ مِنْهُ"
      },
      {
        "start": "00:00:25,042",
        "end": "00:00:26,102",
        "text": "نَبِيُّكَ مُحَمَّدٌ"
      },
      {
        "start": "00:00:26,455",
        "end": "00:00:29,246",
        "text": "صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ"
      },
      {
        "start": "00:00:29,422",
        "end": "00:00:30,800",
        "text": "وَأَعُوذُ بِكَ"
      },
      {
        "start": "00:00:30,800",
        "end": "00:00:33,131",
        "text": "مِنْ شَرِّ مَا اسْتَعَاذَكَ مِنْهُ"
      },
      {
        "start": "00:00:33,166",
        "end": "00:00:35,003",
        "text": "نَبِيُّكَ مُحَمَّدٌ"
      },
      {
        "start": "00:00:35,003",
        "end": "00:00:38,182",
        "text": "صَلَّى اللهُ عَلَيْهِ وَسَلَّمَ"
      },
      {
        "start": "00:00:38,253",
        "end": "00:00:40,866",
        "text": "اللَّهُمَّ إِنِّي أَسْأَلُكَ الْجَنَّةَ"
      },
      {
        "start": "00:00:40,831",
        "end": "00:00:42,809",
        "text": "وَنَعِيمَهَا"
      },
      {
        "start": "00:00:42,809",
        "end": "00:00:45,529",
        "text": "وَمَا يُقَرِّبُنِي إِلَيْهَا"
      },
      {
        "start": "00:00:45,529",
        "end": "00:00:49,555",
        "text": "مِنْ قَوْلٍ أَوْ فِعْلٍ أَوْ عَمَلٍ"
      },
      {
        "start": "00:00:49,661",
        "end": "00:00:51,816",
        "text": "وَأَعُوذُ بِكَ مِنَ النَّارِ"
      },
      {
        "start": "00:00:52,240",
        "end": "00:00:54,606",
        "text": "وَمَا يُقَرِّبُنِي إِلَيْهَا"
      },
      {
        "start": "00:00:54,606",
        "end": "00:05:08,350",
        "text": "مِنْ قَوْلٍ أَوْ فِعْلٍ أَوْ عَمَلٍ"
      }
    ],
    "tl": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,165",
        "text": "Allahumma"
      },
      {
        "start": "00:00:01,165",
        "end": "00:00:03,284",
        "text": "azhillani tahta zhilli 'arshika"
      },
      {
        "start": "00:00:03,284",
        "end": "00:00:06,322",
        "text": "yawma la zhilla illa zhilluka"
      },
      {
        "start": "00:00:06,322",
        "end": "00:00:09,148",
        "text": "wa la baqiya illa wajhuka"
      },
      {
        "start": "00:00:09,148",
        "end": "00:00:11,938",
        "text": "wasqini min hawzhi nabiyyika"
      },
      {
        "start": "00:00:11,867",
        "end": "00:00:15,541",
        "text": "Muhammadin sallallahu 'alayhi wa sallam"
      },
      {
        "start": "00:00:15,576",
        "end": "00:00:17,837",
        "text": "sharbatan hani'atan"
      },
      {
        "start": "00:00:17,801",
        "end": "00:00:20,592",
        "text": "la nazhma'u ba'daha abada"
      },
      {
        "start": "00:00:20,627",
        "end": "00:00:21,581",
        "text": "Allahumma"
      },
      {
        "start": "00:00:21,546",
        "end": "00:00:23,135",
        "text": "inni as'aluka"
      },
      {
        "start": "00:00:23,064",
        "end": "00:00:25,078",
        "text": "min khayri ma sa'alaka minhu"
      },
      {
        "start": "00:00:25,042",
        "end": "00:00:26,102",
        "text": "nabiyyuka Muhammadun"
      },
      {
        "start": "00:00:26,455",
        "end": "00:00:29,246",
        "text": "sallallahu 'alayhi wa sallam"
      },
      {
        "start": "00:00:29,422",
        "end": "00:00:30,800",
        "text": "wa a'udhu bika"
      },
      {
        "start": "00:00:30,800",
        "end": "00:00:33,131",
        "text": "min sharri masta'adhaka minhu"
      },
      {
        "start": "00:00:33,166",
        "end": "00:00:35,003",
        "text": "nabiyyuka Muhammadun"
      },
      {
        "start": "00:00:35,003",
        "end": "00:00:38,182",
        "text": "sallallahu 'alayhi wa sallam"
      },
      {
        "start": "00:00:38,253",
        "end": "00:00:40,866",
        "text": "Allahumma inni as'alukal-jannah"
      },
      {
        "start": "00:00:40,831",
        "end": "00:00:42,809",
        "text": "wa na'imaha"
      },
      {
        "start": "00:00:42,809",
        "end": "00:00:45,529",
        "text": "wa ma yuqarribuni ilayha"
      },
      {
        "start": "00:00:45,529",
        "end": "00:00:49,555",
        "text": "min qawlin aw fi'lin aw 'amal"
      },
      {
        "start": "00:00:49,661",
        "end": "00:00:51,816",
        "text": "wa a'udhu bika minan-nar"
      },
      {
        "start": "00:00:52,240",
        "end": "00:00:54,606",
        "text": "wa ma yuqarribuni ilayha"
      },
      {
        "start": "00:00:54,606",
        "end": "00:05:08,350",
        "text": "min qawlin aw fi'lin aw 'amal"
      }
    ],
    "ms": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,165",
        "text": "Ya Allah"
      },
      {
        "start": "00:00:01,165",
        "end": "00:00:03,284",
        "text": "Lindungilah aku di bawah naungan Arasy-Mu"
      },
      {
        "start": "00:00:03,284",
        "end": "00:00:06,322",
        "text": "Pada hari yang tiada naungan melainkan naungan-Mu"
      },
      {
        "start": "00:00:06,322",
        "end": "00:00:09,148",
        "text": "Dan tiada yang kekal melainkan Zat-Mu"
      },
      {
        "start": "00:00:09,148",
        "end": "00:00:11,938",
        "text": "Dan berilah aku minum dari kolam Nabi-Mu"
      },
      {
        "start": "00:00:11,867",
        "end": "00:00:15,541",
        "text": "Muhammad SAW"
      },
      {
        "start": "00:00:15,576",
        "end": "00:00:17,837",
        "text": "Dengan minuman yang lazat"
      },
      {
        "start": "00:00:17,801",
        "end": "00:00:20,592",
        "text": "Yang kami tidak akan dahaga selepasnya buat selama-lamanya"
      },
      {
        "start": "00:00:20,627",
        "end": "00:00:21,581",
        "text": "Ya Allah"
      },
      {
        "start": "00:00:21,546",
        "end": "00:00:23,135",
        "text": "Sesungguhnya aku memohon kepada-Mu"
      },
      {
        "start": "00:00:23,064",
        "end": "00:00:25,078",
        "text": "Segala kebaikan yang pernah dipohon oleh"
      },
      {
        "start": "00:00:25,042",
        "end": "00:00:26,102",
        "text": "Nabi-Mu Muhammad"
      },
      {
        "start": "00:00:26,455",
        "end": "00:00:29,246",
        "text": "Selawat dan salam ke atasnya"
      },
      {
        "start": "00:00:29,422",
        "end": "00:00:30,800",
        "text": "Dan aku berlindung dengan-Mu"
      },
      {
        "start": "00:00:30,800",
        "end": "00:00:33,131",
        "text": "Dari kejahatan yang pernah dipohon perlindungan oleh"
      },
      {
        "start": "00:00:33,166",
        "end": "00:00:35,003",
        "text": "Nabi-Mu Muhammad"
      },
      {
        "start": "00:00:35,003",
        "end": "00:00:38,182",
        "text": "Selawat dan salam ke atasnya"
      },
      {
        "start": "00:00:38,253",
        "end": "00:00:40,866",
        "text": "Ya Allah, aku memohon kepada-Mu syurga"
      },
      {
        "start": "00:00:40,831",
        "end": "00:00:42,809",
        "text": "Dan segala nikmatnya"
      },
      {
        "start": "00:00:42,809",
        "end": "00:00:45,529",
        "text": "Serta apa yang boleh mendekatkan aku kepadanya"
      },
      {
        "start": "00:00:45,529",
        "end": "00:00:49,555",
        "text": "Sama ada perkataan, perbuatan atau amalan"
      },
      {
        "start": "00:00:49,661",
        "end": "00:00:51,816",
        "text": "Dan aku berlindung dengan-Mu dari neraka"
      },
      {
        "start": "00:00:52,240",
        "end": "00:00:54,606",
        "text": "Serta apa yang boleh mendekatkan aku kepadanya"
      },
      {
        "start": "00:00:54,606",
        "end": "00:05:08,350",
        "text": "Sama ada perkataan, perbuatan atau amalan"
      }
    ],
    "en": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,165",
        "text": "O Allah"
      },
      {
        "start": "00:00:01,165",
        "end": "00:00:03,284",
        "text": "Shade me under the shade of Your Throne"
      },
      {
        "start": "00:00:03,284",
        "end": "00:00:06,322",
        "text": "On the day when there is no shade but Your shade"
      },
      {
        "start": "00:00:06,322",
        "end": "00:00:09,148",
        "text": "And nothing remains but Your Face"
      },
      {
        "start": "00:00:09,148",
        "end": "00:00:11,938",
        "text": "And give me to drink from the Cistern of Your Prophet"
      },
      {
        "start": "00:00:11,867",
        "end": "00:00:15,541",
        "text": "Muhammad, peace and blessings be upon him"
      },
      {
        "start": "00:00:15,576",
        "end": "00:00:17,837",
        "text": "A pleasant, delicious drink"
      },
      {
        "start": "00:00:17,801",
        "end": "00:00:20,592",
        "text": "After which we will never feel thirst again"
      },
      {
        "start": "00:00:20,627",
        "end": "00:00:21,581",
        "text": "O Allah"
      },
      {
        "start": "00:00:21,546",
        "end": "00:00:23,135",
        "text": "Indeed, I ask You"
      },
      {
        "start": "00:00:23,064",
        "end": "00:00:25,078",
        "text": "For the best of what was asked of You by"
      },
      {
        "start": "00:00:25,042",
        "end": "00:00:26,102",
        "text": "Your Prophet Muhammad"
      },
      {
        "start": "00:00:26,455",
        "end": "00:00:29,246",
        "text": "Peace and blessings be upon him"
      },
      {
        "start": "00:00:29,422",
        "end": "00:00:30,800",
        "text": "And I seek refuge in You"
      },
      {
        "start": "00:00:30,800",
        "end": "00:00:33,131",
        "text": "From the evil from which refuge was sought by"
      },
      {
        "start": "00:00:33,166",
        "end": "00:00:35,003",
        "text": "Your Prophet Muhammad"
      },
      {
        "start": "00:00:35,003",
        "end": "00:00:38,182",
        "text": "Peace and blessings be upon him"
      },
      {
        "start": "00:00:38,253",
        "end": "00:00:40,866",
        "text": "O Allah, I ask You for Paradise"
      },
      {
        "start": "00:00:40,831",
        "end": "00:00:42,809",
        "text": "And its bliss"
      },
      {
        "start": "00:00:42,809",
        "end": "00:00:45,529",
        "text": "And what brings me closer to it"
      },
      {
        "start": "00:00:45,529",
        "end": "00:00:49,555",
        "text": "Of speech, action, or deed"
      },
      {
        "start": "00:00:49,661",
        "end": "00:00:51,816",
        "text": "And I seek refuge in You from the Fire"
      },
      {
        "start": "00:00:52,240",
        "end": "00:00:54,606",
        "text": "And what brings me closer to it"
      },
      {
        "start": "00:00:54,606",
        "end": "00:05:08,350",
        "text": "Of speech, action, or deed"
      }
    ],
    "ml": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,165",
        "text": "അല്ലാഹുവേ"
      },
      {
        "start": "00:00:01,165",
        "end": "00:00:03,284",
        "text": "നിന്റെ അർശിന്റെ തണലിൽ എനിക്ക് തണലേകേണമേ"
      },
      {
        "start": "00:00:03,284",
        "end": "00:00:06,322",
        "text": "നിന്റെ തണലല്ലാതെ മറ്റൊരു തണലുമില്ലാത്ത ആ ദിവസം"
      },
      {
        "start": "00:00:06,322",
        "end": "00:00:09,148",
        "text": "നിന്റെ മുഖമല്ലാതെ മറ്റൊന്നും അവശേഷിക്കാത്ത ദിവസം"
      },
      {
        "start": "00:00:09,148",
        "end": "00:00:11,938",
        "text": "നിന്റെ പ്രവാചകന്റെ ഹൗളിൽ നിന്നും എനിക്ക് കുടിപ്പിക്കേണമേ"
      },
      {
        "start": "00:00:11,867",
        "end": "00:00:15,541",
        "text": "മുഹമ്മദ് നബി (സ) യുടെ ഹൗളിൽ നിന്ന്"
      },
      {
        "start": "00:00:15,576",
        "end": "00:00:17,837",
        "text": "രുചികരമായ ഒരു പാനീയം"
      },
      {
        "start": "00:00:17,801",
        "end": "00:00:20,592",
        "text": "അതിന് ശേഷം ഒരിക്കലും ദാഹിക്കാത്ത വിധം"
      },
      {
        "start": "00:00:20,627",
        "end": "00:00:21,581",
        "text": "അല്ലാഹുവേ"
      },
      {
        "start": "00:00:21,546",
        "end": "00:00:23,135",
        "text": "ഞാൻ നിന്നോട് ചോദിക്കുന്നു"
      },
      {
        "start": "00:00:23,064",
        "end": "00:00:25,078",
        "text": "നിന്നോട് ചോദിച്ചതിൽ വെച്ച് ഏറ്റവും ഉത്തമമായത്"
      },
      {
        "start": "00:00:25,042",
        "end": "00:00:26,102",
        "text": "നിന്റെ പ്രവാചകൻ മുഹമ്മദ് നബി (സ)"
      },
      {
        "start": "00:00:26,455",
        "end": "00:00:29,246",
        "text": "അവിടുത്തെ മേൽ അല്ലാഹുവിന്റെ രക്ഷയും സമാധാനവും ഉണ്ടാകട്ടെ"
      },
      {
        "start": "00:00:29,422",
        "end": "00:00:30,800",
        "text": "ഞാൻ നിന്നോട് കാവൽ തേടുന്നു"
      },
      {
        "start": "00:00:30,800",
        "end": "00:00:33,131",
        "text": "ഏതൊരു തിന്മയിൽ നിന്നാണോ കാവൽ തേടിയത്"
      },
      {
        "start": "00:00:33,166",
        "end": "00:00:35,003",
        "text": "നിന്റെ പ്രവാചകൻ മുഹമ്മദ് നബി (സ)"
      },
      {
        "start": "00:00:35,003",
        "end": "00:00:38,182",
        "text": "അവിടുത്തെ മേൽ അല്ലാഹുവിന്റെ രക്ഷയും സമാധാനവും ഉണ്ടാകട്ടെ"
      },
      {
        "start": "00:00:38,253",
        "end": "00:00:40,866",
        "text": "അല്ലാഹുവേ, ഞാൻ നിന്നോട് സ്വർഗ്ഗത്തെ ചോദിക്കുന്നു"
      },
      {
        "start": "00:00:40,831",
        "end": "00:00:42,809",
        "text": "അതിലെ അനുഗ്രഹങ്ങളെയും"
      },
      {
        "start": "00:00:42,809",
        "end": "00:00:45,529",
        "text": "അതിലേക്ക് എന്നെ അടുപ്പിക്കുന്നവയെയും"
      },
      {
        "start": "00:00:45,529",
        "end": "00:00:49,555",
        "text": "വാക്കുകളോ പ്രവൃത്തികളോ കർമ്മങ്ങളോ ആകട്ടെ"
      },
      {
        "start": "00:00:49,661",
        "end": "00:00:51,816",
        "text": "നരകത്തിൽ നിന്നും ഞാൻ നിന്നോട് കാവൽ തേടുന്നു"
      },
      {
        "start": "00:00:52,240",
        "end": "00:00:54,606",
        "text": "അതിലേക്ക് എന്നെ അടുപ്പിക്കുന്നവയിൽ നിന്നും"
      },
      {
        "start": "00:00:54,606",
        "end": "00:05:08,350",
        "text": "വാക്കുകളോ പ്രവൃത്തികളോ കർമ്മങ്ങളോ ആകട്ടെ"
      }
    ],
    "ta": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,165",
        "text": "யா அல்லாஹ்"
      },
      {
        "start": "00:00:01,165",
        "end": "00:00:03,284",
        "text": "உன் அர்ஷின் நிழலில் எனக்கு நிழல் தருவாயாக"
      },
      {
        "start": "00:00:03,284",
        "end": "00:00:06,322",
        "text": "உன் நிழலைத் தவிர வேறு நிழல் இல்லாத அந்த நாளில்"
      },
      {
        "start": "00:00:06,322",
        "end": "00:00:09,148",
        "text": "உன் திருமுகத்தைத் தவிர வேறு எதுவும் நிலைத்திராத நாளில்"
      },
      {
        "start": "00:00:09,148",
        "end": "00:00:11,938",
        "text": "உன் நபியின் ஹவ்ளிலிருந்து எனக்குப் புகட்டுவாயாக"
      },
      {
        "start": "00:00:11,867",
        "end": "00:00:15,541",
        "text": "முஹம்மது (ஸல்) அவர்களின் ஹவ்ளிலிருந்து"
      },
      {
        "start": "00:00:15,576",
        "end": "00:00:17,837",
        "text": "சுவையான ஒரு பானத்தை"
      },
      {
        "start": "00:00:17,801",
        "end": "00:00:20,592",
        "text": "அதன் பின் எக்காலமும் நாங்கள் தாகிக்காதவாறு"
      },
      {
        "start": "00:00:20,627",
        "end": "00:00:21,581",
        "text": "யா அல்லாஹ்"
      },
      {
        "start": "00:00:21,546",
        "end": "00:00:23,135",
        "text": "நிச்சயமாக நான் உன்னிடம் கேட்கிறேன்"
      },
      {
        "start": "00:00:23,064",
        "end": "00:00:25,078",
        "text": "உன்னிடம் கேட்கப்பட்டவற்றில் மிகச் சிறந்ததை"
      },
      {
        "start": "00:00:25,042",
        "end": "00:00:26,102",
        "text": "உன் நபி முஹம்மது (ஸல்) அவர்கள்"
      },
      {
        "start": "00:00:26,455",
        "end": "00:00:29,246",
        "text": "அவர் மீது அல்லாஹ்வின் அருளும் சாந்தியும் உண்டாகட்டும்"
      },
      {
        "start": "00:00:29,422",
        "end": "00:00:30,800",
        "text": "மேலும் உன்னிடம் பாதுகாப்புத் தேடுகிறேன்"
      },
      {
        "start": "00:00:30,800",
        "end": "00:00:33,131",
        "text": "எந்தத் தீங்கிலிருந்து பாதுகாப்புத் தேடினார்களோ"
      },
      {
        "start": "00:00:33,166",
        "end": "00:00:35,003",
        "text": "உன் நபி முஹம்மது (ஸல்) அவர்கள்"
      },
      {
        "start": "00:00:35,003",
        "end": "00:00:38,182",
        "text": "அவர் மீது அல்லாஹ்வின் அருளும் சாந்தியும் உண்டாகட்டும்"
      },
      {
        "start": "00:00:38,253",
        "end": "00:00:40,866",
        "text": "யா அல்லாஹ், உன்னிடம் சுவனத்தை வேண்டுகிறேன்"
      },
      {
        "start": "00:00:40,831",
        "end": "00:00:42,809",
        "text": "அதன் இன்பங்களையும்"
      },
      {
        "start": "00:00:42,809",
        "end": "00:00:45,529",
        "text": "என்னை அதன் பக்கம் நெருக்கமாக்குபவற்றையும்"
      },
      {
        "start": "00:00:45,529",
        "end": "00:00:49,555",
        "text": "சொல்லால், செயலால் அல்லது அமலால்"
      },
      {
        "start": "00:00:49,661",
        "end": "00:00:51,816",
        "text": "நரகத்தை விட்டும் உன்னிடம் பாதுகாப்புத் தேடுகிறேன்"
      },
      {
        "start": "00:00:52,240",
        "end": "00:00:54,606",
        "text": "என்னை அதன் பக்கம் நெருக்கமாக்குபவற்றிலிருந்தும்"
      },
      {
        "start": "00:00:54,606",
        "end": "00:05:08,350",
        "text": "சொல்லால், செயலால் அல்லது அமலால்"
      }
    ]
  }
}