        "text": "wal-mamat"
      }
    ],
    "ms": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,200",
        "text": "Ya Allah"
      },
      {
        "start": "00:00:01,200",
        "end": "00:00:02,692",
        "text": "Sesungguhnya aku berlindung dengan-Mu"
      },
      {
        "start": "00:00:02,710",
        "end": "00:00:05,720",
        "text": "Daripada ragu-ragu dan syirik"
      },
      {
        "start": "00:00:05,683",
        "end": "00:00:08,562",
        "text": "Perbalahan dan nifaq"
      },
      {
        "start": "00:00:08,599",
        "end": "00:00:10,132",
        "text": "Dan buruk akhlak"
      },
      {
        "start": "00:00:10,170",
        "end": "00:00:11,646",
        "text": "Dan buruk pemandangan"
      },
      {
        "start": "00:00:11,684",
        "end": "00:00:12,413",
        "text": "Dan kepulangan yang buruk"
      },
      {
        "start": "00:00:12,432",
        "end": "00:00:13,591",
        "text": "Pada harta benda"
      },
      {
        "start": "00:00:13,591",
        "end": "00:00:16,470",
        "text": "Keluarga dan anak-anak"
      },
      {
        "start": "00:00:16,582",
        "end": "00:00:17,143",
        "text": "Ya Allah"
      },
      {
        "start": "00:00:17,068",
        "end": "00:00:18,657",
        "text": "Sesungguhnya aku memohon kepada-Mu"
      },
      {
        "start": "00:00:18,657",
        "end": "00:00:20,975",
        "text": "Keredaan-Mu dan syurga"
      },
      {
        "start": "00:00:20,956",
        "end": "00:00:22,415",
        "text": "Dan aku berlindung dengan-Mu"
      },
      {
        "start": "00:00:22,452",
        "end": "00:00:24,733",
        "text": "Daripada kemurkaan-Mu dan neraka"
      },
      {
        "start": "00:00:24,920",
        "end": "00:00:25,481",
        "text": "Ya Allah"
      },
      {
        "start": "00:00:25,462",
        "end": "00:00:27,257",
        "text": "Sesungguhnya aku berlindung dengan-Mu"
      },
      {
        "start": "00:00:27,257",
        "end": "00:00:29,145",
        "text": "Daripada fitnah kubur"
      },
      {
        "start": "00:00:29,182",
        "end": "00:00:30,603",
        "text": "Dan daripada fitnah kehidupan"
      },
      {
        "start": "00:00:30,584",
        "end": "00:00:31,800",
        "text": "Serta kematian"
      }
    ],
    "en": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,200",
        "text": "O Allah"
      },
      {
        "start": "00:00:01,200",
        "end": "00:00:02,692",
        "text": "I seek refuge in You"
      },
      {
        "start": "00:00:02,710",
        "end": "00:00:05,720",
        "text": "From doubt and shirk"
      },
      {
        "start": "00:00:05,683",
        "end": "00:00:08,562",
        "text": "Discord and hypocrisy"
      },
      {
        "start": "00:00:08,599",
        "end": "00:00:10,132",
        "text": "And bad character"
      },
      {
        "start": "00:00:10,170",
        "end": "00:00:11,646",
        "text": "And an ill appearance"
      },
      {
        "start": "00:00:11,684",
        "end": "00:00:12,413",
        "text": "And an evil return"
      },
      {
        "start": "00:00:12,432",
        "end": "00:00:13,591",
        "text": "In wealth"
      },
      {
        "start": "00:00:13,591",
        "end": "00:00:16,470",
        "text": "Family and children"
      },
      {
        "start": "00:00:16,582",
        "end": "00:00:17,143",
        "text": "O Allah"
      },
      {
        "start": "00:00:17,068",
        "end": "00:00:18,657",
        "text": "I ask You for"
      },
      {
        "start": "00:00:18,657",
        "end": "00:00:20,975",
        "text": "Your pleasure and Paradise"
      },
      {
        "start": "00:00:20,956",
        "end": "00:00:22,415",
        "text": "And I seek refuge in You"
      },
      {
        "start": "00:00:22,452",
        "end": "00:00:24,733",
        "text": "From Your wrath and the Fire"
      },
      {
        "start": "00:00:24,920",
        "end": "00:00:25,481",
        "text": "O Allah"
      },
      {
        "start": "00:00:25,462",
        "end": "00:00:27,257",
        "text": "I seek refuge in You"
      },
      {
        "start": "00:00:27,257",
        "end": "00:00:29,145",
        "text": "From the trial of the grave"
      },
      {
        "start": "00:00:29,182",
        "end": "00:00:30,603",
        "text": "And from the trials of life"
      },
      {
        "start": "00:00:30,584",
        "end": "00:00:31,800",
        "text": "And death"
      }
    ],
    "ml": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,200",
        "text": "അല്ലാഹുവേ"
      },
      {
        "start": "00:00:01,200",
        "end": "00:00:02,692",
        "text": "ഞാൻ നിന്നോട് കാവൽ തേടുന്നു"
      },
      {
        "start": "00:00:02,710",
        "end": "00:00:05,720",
        "text": "സംശയത്തിൽ നിന്നും ശിർക്കിൽ നിന്നും"
      },
      {
        "start": "00:00:05,683",
        "end": "00:00:08,562",
        "text": "പിണക്കത്തിൽ നിന്നും കാപട്യത്തിൽ നിന്നും"
      },
      {
        "start": "00:00:08,599",
        "end": "00:00:10,132",
        "text": "ദുസ്വഭാവത്തിൽ നിന്നും"
      },
      {
        "start": "00:00:10,170",
        "end": "00:00:11,646",
        "text": "മോശമായ കാഴ്ചയിൽ നിന്നും"
      },
      {
        "start": "00:00:11,684",
        "end": "00:00:12,413",
        "text": "തിരിച്ചുവരവിൽ നിന്നും"
      },
      {
        "start": "00:00:12,432",
        "end": "00:00:13,591",
        "text": "സമ്പത്തിലും"
      },
      {
        "start": "00:00:13,591",
        "end": "00:00:16,470",
        "text": "കുടുംബത്തിലും സന്താനങ്ങളിലും"
      },
      {
        "start": "00:00:16,582",
        "end": "00:00:17,143",
        "text": "അല്ലാഹുവേ"
      },
      {
        "start": "00:00:17,068",
        "end": "00:00:18,657",
        "text": "ഞാൻ നിന്നോട് ചോദിക്കുന്നു"
      },
      {
        "start": "00:00:18,657",
        "end": "00:00:20,975",
        "text": "നിന്റെ പ്രീതിയും സ്വർഗ്ഗവും"
      },
      {
        "start": "00:00:20,956",
        "end": "00:00:22,415",
        "text": "ഞാൻ നിന്നോട് കാവൽ തേടുന്നു"
      },
      {
        "start": "00:00:22,452",
        "end": "00:00:24,733",
        "text": "നിന്റെ കോപത്തിൽ നിന്നും നരകത്തിൽ നിന്നും"
      },
      {
        "start": "00:00:24,920",
        "end": "00:00:25,481",
        "text": "അല്ലാഹുവേ"
      },
      {
        "start": "00:00:25,462",
        "end": "00:00:27,257",
        "text": "ഞാൻ നിന്നോട് കാവൽ തേടുന്നു"
      },
      {
        "start": "00:00:27,257",
        "end": "00:00:29,145",
        "text": "ഖബറിലെ പരീക്ഷണത്തിൽ നിന്നും"
      },
      {
        "start": "00:00:29,182",
        "end": "00:00:30,603",
        "text": "ജീവിതത്തിലെ പരീക്ഷണങ്ങളിൽ നിന്നും"
      },
      {
        "start": "00:00:30,584",
        "end": "00:00:31,800",
        "text": "മരണത്തിലെ പരീക്ഷണങ്ങളിൽ നിന്നും"
      }
    ],
    "ta": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,200",
        "text": "யா அல்லாஹ்"
      },
      {
        "start": "00:00:01,200",
        "end": "00:00:02,692",
        "text": "நிச்சயமாக நான் உன்னிடம் பாதுகாப்புத் தேடுகிறேன்"
      },
      {
        "start": "00:00:02,710",
        "end": "00:00:05,720",
        "text": "சந்தேகத்திலிருந்தும் இணைவைப்பிலிருந்தும்"
      },
      {
        "start": "00:00:05,683",
        "end": "00:00:08,562",
        "text": "பிணக்கிலிருந்தும் நயவஞ்சகத்திலிருந்தும்"
      },
      {
        "start": "00:00:08,599",
        "end": "00:00:10,132",
        "text": "தீய குணத்திலிருந்தும்"
      },
      {
        "start": "00:00:10,170",
        "end": "00:00:11,646",
        "text": "கெட்ட தோற்றத்திலிருந்தும்"
      },
      {
        "start": "00:00:11,684",
        "end": "00:00:12,413",
        "text": "கெட்ட மாற்றத்திலிருந்தும்"
      },
      {
        "start": "00:00:12,432",
        "end": "00:00:13,591",
        "text": "செல்வத்திலும்"
      },
      {
        "start": "00:00:13,591",
        "end": "00:00:16,470",
        "text": "குடும்பத்திலும் பிள்ளைகளிலும்"
      },
      {
        "start": "00:00:16,582",
        "end": "00:00:17,143",
        "text": "யா அல்லாஹ்"
      },
      {
        "start": "00:00:17,068",
        "end": "00:00:18,657",
        "text": "நிச்சயமாக நான் உன்னிடம் கேட்கிறேன்"
      },
      {
        "start": "00:00:18,657",
        "end": "00:00:20,975",
        "text": "உன் பொருத்தத்தையும் சுவனத்தையும்"
      },
      {
        "start": "00:00:20,956",
        "end": "00:00:22,415",
        "text": "மேலும் உன்னிடம் பாதுகாப்புத் தேடுகிறேன்"
      },
      {
        "start": "00:00:22,452",
        "end": "00:00:24,733",
        "text": "உன் கோபத்திலிருந்தும் நரகத்திலிருந்தும்"
      },
      {
        "start": "00:00:24,920",
        "end": "00:00:25,481",
        "text": "யா அல்லாஹ்"
      },
      {
        "start": "00:00:25,462",
        "end": "00:00:27,257",
        "text": "நிச்சயமாக நான் உன்னிடம் பாதுகாப்புத் தேடுகிறேன்"
      },
      {
        "start": "00:00:27,257",
        "end": "00:00:29,145",
        "text": "மண்ணறையின் சோதனையிலிருந்தும்"
      },
      {
        "start": "00:00:29,182",
        "end": "00:00:30,603",
        "text": "வாழ்வின் சோதனையிலிருந்தும்"
      },
      {
        "start": "00:00:30,584",
        "end": "00:00:31,800",
        "text": "மரணத்தின் சோதனையிலிருந்தும்"
      }
    ]
  }
}