        "text": "wa su'il-manzhari"
      },
      {
        "start": "00:00:11,684",
        "end": "00:00:12,413",
        "text": "wal-munqalab"
      },
      {
        "start": "00:00:12,432",
        "end": "00:00:13,591",
        "text": "fil-mali"
      },
      {
        "start": "00:00:13,591",
        "end": "00:00:16,470",
        "text": "wal-ahli wal-walad"
      },
      {
        "start": "00:00:16,582",
        "end": "00:00:17,143",
        "text": "Allahumma"
      },
      {
        "start": "00:00:17,068",
