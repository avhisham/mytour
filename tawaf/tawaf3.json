      },
      {
        "start": "00:00:18,657",
        "end": "00:00:20,975",
        "text": "ridhaka wal-jannah"
      },
      {
        "start": "00:00:20,956",
        "end": "00:00:22,415",
        "text": "wa a'udhu bika"
      },
      {
        "start": "00:00:22,452",
        "end": "00:00:24,733",
        "text": "min sakhatika wan-nar"
      },
      {
        "start": "00:00:24,920",
        "end": "00:00:25,481",
        "text": "Allahumma"
      },
      {
        "start": "00:00:25,462",
