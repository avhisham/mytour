{
  "file_name": "tawaf3.mp3",
  "subtitles": {
    "ar": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,200",
        "text": "اللَّهُمَّ"
      },
      {
        "start": "00:00:01,200",
        "end": "00:00:02,692",
        "text": "إِنِّي أَعُوذُ بِكَ"
      },
      {
        "start": "00:00:02,710",
        "end": "00:00:05,720",
        "text": "مِنَ الشَّكِّ وَالشِّرْكِ"
      },
      {
        "start": "00:00:05,683",
        "end": "00:00:08,562",
        "text": "وَالشِّقَاقِ وَالنِّفَاقِ"
      },
      {
        "start": "00:00:08,599",
        "end": "00:00:10,132",
        "text": "وَسُوءِ الْأَخْلَاقِ"
      },
      {
        "start": "00:00:10,170",
        "end": "00:00:11,646",
        "text": "وَسُوءِ الْمَنْظَرِ"
      },
      {
        "start": "00:00:11,684",
        "end": "00:00:12,413",
        "text": "وَالْمُنْقَلَبِ"
      },
      {
        "start": "00:00:12,432",
        "end": "00:00:13,591",
        "text": "فِي الْمَالِ"
      },
      {
        "start": "00:00:13,591",
        "end": "00:00:16,470",
        "text": "وَالْأَهْلِ وَالْوَلَدِ"
      },
      {
        "start": "00:00:16,582",
        "end": "00:00:17,143",
        "text": "اللَّهُمَّ"
      },
      {
        "start": "00:00:17,068",
        "end": "00:00:18,657",
        "text": "إِنِّي أَسْأَلُكَ"
      },
      {
        "start": "00:00:18,657",
        "end": "00:00:20,975",
        "text": "رِضَاكَ وَالْجَنَّةَ"
      },
      {
        "start": "00:00:20,956",
        "end": "00:00:22,415",
        "text": "وَأَعُوذُ بِكَ"
      },
      {
        "start": "00:00:22,452",
        "end": "00:00:24,733",
        "text": "مِنْ سَخَطِكَ وَالنَّارِ"
      },
      {
        "start": "00:00:24,920",
        "end": "00:00:25,481",
        "text": "اللَّهُمَّ"
      },
      {
        "start": "00:00:25,462",
        "end": "00:00:27,257",
        "text": "إِنِّي أَعُوذُ بِكَ"
      },
      {
        "start": "00:00:27,257",
        "end": "00:00:29,145",
        "text": "مِنْ فِتْنَةِ الْقَبْرِ"
      },
      {
        "start": "00:00:29,182",
        "end": "00:00:30,603",
        "text": "وَ مِنْ فِتْنَةِ الْمَحْيَا"
      },
      {
        "start": "00:00:30,584",
        "end": "00:00:31,800",
        "text": "وَالْمَمَاتِ"
      }
    ],
    "tl": [
