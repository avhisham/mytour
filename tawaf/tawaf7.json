{
  "file_name": "tawaf7.mp3",
  "subtitles": {
    "ar": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,500",
        "text": "اللَّهُمَّ"
      },
      {
        "start": "00:00:01,500",
        "end": "00:00:03,500",
        "text": "إِنِّي أَسْأَلُكَ"
      },
      {
        "start": "00:00:03,500",
        "end": "00:00:05,500",
        "text": "إِيمَانًا كَامِلًا"
      },
      {
        "start": "00:00:05,500",
        "end": "00:00:07,500",
        "text": "وَيَقِينًا صَادِقًا"
      },
      {
        "start": "00:00:07,500",
        "end": "00:00:09,881",
        "text": "وَرِزْقًا وَاسِعًا"
      },
      {
        "start": "00:00:09,834",
        "end": "00:00:12,139",
        "text": "وَقَلْبًا خَاشِعًا"
      },
      {
        "start": "00:00:12,139",
        "end": "00:00:14,398",
        "text": "وَلِسَانًا ذَاكِرًا"
      },
      {
        "start": "00:00:14,398",
        "end": "00:00:16,986",
        "text": "وَرِزْقًا حَلَالًا طَيِّبًا"
      },
      {
        "start": "00:00:16,963",
        "end": "00:00:19,386",
        "text": "وَتَوْبَةً قَبْلَ الْمَوْتِ"
      },
      {
        "start": "00:00:19,339",
        "end": "00:00:21,691",
        "text": "وَمَغْفِرَةً وَرَحْمَةً"
      },
      {
        "start": "00:00:21,691",
        "end": "00:00:23,500",
        "text": "بَعْدَ الْمَوْتِ"
      },
      {
        "start": "00:00:23,500",
        "end": "00:00:26,162",
        "text": "وَالْعَفْوَ عِنْدَ الْحِسَابِ"
      },
      {
        "start": "00:00:26,138",
        "end": "00:00:28,373",
        "text": "وَالْفَوْزَ بِالْجَنَّةِ"
      },
      {
        "start": "00:00:28,350",
        "end": "00:00:30,773",
        "text": "وَالنَّجَاةَ مِنَ النَّارِ"
      },
      {
        "start": "00:00:30,702",
        "end": "00:00:31,714",
        "text": "بِرَحْمَتِكَ"
      },
      {
        "start": "00:00:31,714",
        "end": "00:00:35,055",
        "text": "يَا عَزِيزُ يَا غَفَّارُ"
      },
      {
        "start": "00:00:35,008",
        "end": "00:00:37,361",
        "text": "رَبِّ زِدْنِي عِلْمًا"
      },
      {
        "start": "00:00:37,337",
        "end": "00:00:40,000",
        "text": "وَأَلْحِقْنِي بِالصَّالِحِينَ"
      }
    ],
    "tl": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,500",
        "text": "Allahumma"
      },
      {
        "start": "00:00:01,500",
        "end": "00:00:03,500",
        "text": "inni as'aluka"
      },
      {
        "start": "00:00:03,500",
        "end": "00:00:05,500",
        "text": "imanan kamilan"
      },
      {
        "start": "00:00:05,500",
        "end": "00:00:07,500",
        "text": "wa yaqinan sadiqan"
      },
      {
        "start": "00:00:07,500",
        "end": "00:00:09,881",
        "text": "wa rizqan wasi'an"
      },
      {
        "start": "00:00:09,834",
        "end": "00:00:12,139",
        "text": "wa qalban khashi'an"
      },
      {
        "start": "00:00:12,139",
        "end": "00:00:14,398",
        "text": "wa lisanan dhakiran"
      },
      {
        "start": "00:00:14,398",
        "end": "00:00:16,986",
        "text": "wa rizqan halalan tayyiban"
      },
      {
        "start": "00:00:16,963",
        "end": "00:00:19,386",
        "text": "wa tawbatan qablal mawt"
      },
      {
        "start": "00:00:19,339",
        "end": "00:00:21,691",
        "text": "wa maghfiratan wa rahmatan"
      },
      {
        "start": "00:00:21,691",
        "end": "00:00:23,500",
        "text": "ba'dal mawt"
      },
      {
        "start": "00:00:23,500",
        "end": "00:00:26,162",
        "text": "wal 'afwa 'indal hisab"
      },
      {
        "start": "00:00:26,138",
        "end": "00:00:28,373",
        "text": "wal fawza bil jannah"
      },
      {
        "start": "00:00:28,350",
        "end": "00:00:30,773",
        "text": "wan najata minan nar"
      },
      {
        "start": "00:00:30,702",
        "end": "00:00:31,714",
        "text": "birahmatika"
      },
      {
        "start": "00:00:31,714",
        "end": "00:00:35,055",
        "text": "ya 'azizu ya ghaffar"
      },
      {
        "start": "00:00:35,008",
        "end": "00:00:37,361",
        "text": "rabbi zidni 'ilman"
      },
      {
        "start": "00:00:37,337",
        "end": "00:00:40,000",
        "text": "wa alhiqni bis-salihin"
      }
    ],
    "ms": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,500",
        "text": "Ya Allah"
      },
      {
        "start": "00:00:01,500",
        "end": "00:00:03,500",
        "text": "Sesungguhnya aku memohon kepada-Mu"
      },
      {
        "start": "00:00:03,500",
        "end": "00:00:05,500",
        "text": "Iman yang sempurna"
      },
      {
        "start": "00:00:05,500",
        "end": "00:00:07,500",
        "text": "Keyakinan yang benar"
      },
      {
        "start": "00:00:07,500",
        "end": "00:00:09,881",
        "text": "Rezeki yang luas"
      },
      {
        "start": "00:00:09,834",
        "end": "00:00:12,139",
        "text": "Hati yang khusyuk"
      },
      {
        "start": "00:00:12,139",
        "end": "00:00:14,398",
        "text": "Lidah yang sentiasa berzikir"
      },
      {
        "start": "00:00:14,398",
        "end": "00:00:16,986",
        "text": "Rezeki yang halal lagi baik"
      },
      {
        "start": "00:00:16,963",
        "end": "00:00:19,386",
        "text": "Taubat sebelum mati"
      },
      {
        "start": "00:00:19,339",
        "end": "00:00:21,691",
        "text": "Keampunan dan rahmat"
      },
      {
        "start": "00:00:21,691",
        "end": "00:00:23,500",
        "text": "Selepas mati"
      },
      {
        "start": "00:00:23,500",
        "end": "00:00:26,162",
        "text": "Kemaafan ketika dihisab"
      },
      {
        "start": "00:00:26,138",
        "end": "00:00:28,373",
        "text": "Kemenangan mendapat syurga"
      },
      {
        "start": "00:00:28,350",
        "end": "00:00:30,773",
        "text": "Keselamatan daripada api neraka"
      },
      {
        "start": "00:00:30,702",
        "end": "00:00:31,714",
        "text": "Dengan rahmat-Mu"
      },
      {
        "start": "00:00:31,714",
        "end": "00:00:35,055",
        "text": "Wahai Tuhan Yang Maha Perkasa lagi Maha Pengampun"
      },
      {
        "start": "00:00:35,008",
        "end": "00:00:37,361",
        "text": "Wahai Tuhanku, tambahkanlah ilmuku"
      },
      {
        "start": "00:00:37,337",
        "end": "00:00:40,000",
        "text": "Dan golongkanlah aku bersama orang-orang soleh"
      }
    ],
    "en": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,500",
        "text": "O Allah"
      },
      {
        "start": "00:00:01,500",
        "end": "00:00:03,500",
        "text": "Indeed, I ask You for"
      },
      {
        "start": "00:00:03,500",
        "end": "00:00:05,500",
        "text": "Perfect faith"
      },
      {
        "start": "00:00:05,500",
        "end": "00:00:07,500",
        "text": "Sincere certainty"
      },
      {
        "start": "00:00:07,500",
        "end": "00:00:09,881",
        "text": "Vast provision"
      },
      {
        "start": "00:00:09,834",
        "end": "00:00:12,139",
        "text": "A humble heart"
      },
      {
        "start": "00:00:12,139",
        "end": "00:00:14,398",
        "text": "A tongue that remembers You"
      },
      {
        "start": "00:00:14,398",
        "end": "00:00:16,986",
        "text": "Lawful and good provision"
      },
      {
        "start": "00:00:16,963",
        "end": "00:00:19,386",
        "text": "Repentance before death"
      },
      {
        "start": "00:00:19,339",
        "end": "00:00:21,691",
        "text": "Forgiveness and mercy"
      },
      {
        "start": "00:00:21,691",
        "end": "00:00:23,500",
        "text": "After death"
      },
      {
        "start": "00:00:23,500",
        "end": "00:00:26,162",
        "text": "Pardon at the time of reckoning"
      },
      {
        "start": "00:00:26,138",
        "end": "00:00:28,373",
        "text": "Success of Paradise"
      },
      {
        "start": "00:00:28,350",
        "end": "00:00:30,773",
        "text": "Salvation from the Fire"
      },
      {
        "start": "00:00:30,702",
        "end": "00:00:31,714",
        "text": "By Your mercy"
      },
      {
        "start": "00:00:31,714",
        "end": "00:00:35,055",
        "text": "O Mighty, O Forgiving"
      },
      {
        "start": "00:00:35,008",
        "end": "00:00:37,361",
        "text": "My Lord, increase me in knowledge"
      },
      {
        "start": "00:00:37,337",
        "end": "00:00:40,000",
        "text": "And join me with the righteous"
      }
    ],
    "ml": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,500",
        "text": "അല്ലാഹുവേ"
      },
      {
        "start": "00:00:01,500",
        "end": "00:00:03,500",
        "text": "ഞാൻ നിന്നോട് ചോദിക്കുന്നു"
      },
      {
        "start": "00:00:03,500",
        "end": "00:00:05,500",
        "text": "പരിപൂർണ്ണമായ ഈമാൻ"
      },
      {
        "start": "00:00:05,500",
        "end": "00:00:07,500",
        "text": "സത്യസന്ധമായ ഉറച്ച വിശ്വാസം"
      },
      {
        "start": "00:00:07,500",
        "end": "00:00:09,881",
        "text": "വിശാലമായ ഉപജീവനം"
      },
      {
        "start": "00:00:09,834",
        "end": "00:00:12,139",
        "text": "ഭയഭക്തിയുള്ള ഹൃദയം"
      },
      {
        "start": "00:00:12,139",
        "end": "00:00:14,398",
        "text": "നിന്നെ സ്മരിക്കുന്ന നാവ്"
      },
      {
        "start": "00:00:14,398",
        "end": "00:00:16,986",
        "text": "അനുവദനീയവും ഉത്തമവുമായ വിഭവങ്ങൾ"
      },
      {
        "start": "00:00:16,963",
        "end": "00:00:19,386",
        "text": "മരണത്തിന് മുമ്പുള്ള തൗബ"
      },
      {
        "start": "00:00:19,339",
        "end": "00:00:21,691",
        "text": "പാപമോചനവും കാരുണ്യവും"
      },
      {
        "start": "00:00:21,691",
        "end": "00:00:23,500",
        "text": "മരണത്തിന് ശേഷം"
      },
      {
        "start": "00:00:23,500",
        "end": "00:00:26,162",
        "text": "വിചാരണാ വേളയിലെ മാപ്പ്"
      },
      {
        "start": "00:00:26,138",
        "end": "00:00:28,373",
        "text": "സ്വർഗ്ഗലബ്ധിയായ വിജയം"
      },
      {
        "start": "00:00:28,350",
        "end": "00:00:30,773",
        "text": "നരകത്തിൽ നിന്നുള്ള രക്ഷ"
      },
      {
        "start": "00:00:30,702",
        "end": "00:00:31,714",
        "text": "നിന്റെ കാരുണ്യം കൊണ്ട്"
      },
      {
        "start": "00:00:31,714",
        "end": "00:00:35,055",
        "text": "പ്രതാപിയും പൊറുക്കുന്നവനുമായവനേ"
      },
      {
        "start": "00:00:35,008",
        "end": "00:00:37,361",
        "text": "എന്റെ നാഥാ, എനിക്ക് അറിവ് വർദ്ധിപ്പിച്ചു തരേണമേ"
      },
      {
        "start": "00:00:37,337",
        "end": "00:00:40,000",
        "text": "എന്നെ സജ്ജനങ്ങളിൽ ചേർക്കേണമേ"
      }
    ],
    "ta": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,500",
        "text": "யா அல்லாஹ்"
      },
      {
        "start": "00:00:01,500",
        "end": "00:00:03,500",
        "text": "நிச்சயமாக நான் உன்னிடம் வேண்டுகிறேன்"
      },
      {
        "start": "00:00:03,500",
        "end": "00:00:05,500",
        "text": "முழுமையான ஈமானை"
      },
      {
        "start": "00:00:05,500",
        "end": "00:00:07,500",
        "text": "உண்மையான உறுதியை"
      },
      {
        "start": "00:00:07,500",
        "end": "00:00:09,881",
        "text": "விசாலமான வாழ்வாதாரத்தை"
      },
      {
        "start": "00:00:09,834",
        "end": "00:00:12,139",
        "text": "பணிவான உள்ளத்தை"
      },
      {
        "start": "00:00:12,139",
        "end": "00:00:14,398",
        "text": "உன்னை நினைவு கூரும் நாவை"
      },
      {
        "start": "00:00:14,398",
        "end": "00:00:16,986",
        "text": "ஹலாலான தூய்மையான உணவை"
      },
      {
        "start": "00:00:16,963",
        "end": "00:00:19,386",
        "text": "மரணத்திற்கு முன் தவ்பாவை"
      },
      {
        "start": "00:00:19,339",
        "end": "00:00:21,691",
        "text": "மன்னிப்பையும் அருளையும்"
      },
      {
        "start": "00:00:21,691",
        "end": "00:00:23,500",
        "text": "மரணத்திற்குப் பின்"
      },
      {
        "start": "00:00:23,500",
        "end": "00:00:26,162",
        "text": "விசாரணையின் போது மன்னிப்பை"
      },
      {
        "start": "00:00:26,138",
        "end": "00:00:28,373",
        "text": "சுவனத்தின் வெற்றியை"
      },
      {
        "start": "00:00:28,350",
        "end": "00:00:30,773",
        "text": "நரகத்திலிருந்து பாதுகாப்பை"
      },
      {
        "start": "00:00:30,702",
        "end": "00:00:31,714",
        "text": "உன் அருளினால்"
      },
      {
        "start": "00:00:31,714",
        "end": "00:00:35,055",
        "text": "கண்ணியமிக்கவனே மன்னிப்பவனே"
      },
      {
        "start": "00:00:35,008",
        "end": "00:00:37,361",
        "text": "என் இறைவா, எனது கல்வியை அதிகப்படுத்து"
      },
      {
        "start": "00:00:37,337",
        "end": "00:00:40,000",
        "text": "என்னை நல்லவர்களுடன் சேர்த்து வை"
      }
    ]
  }
}