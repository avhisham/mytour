{
  "file_name": "tawaf2.mp3",
  "subtitles": {
    "ar": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,800",
        "text": "اللَّهُمَّ"
      },
      {
        "start": "00:00:01,800",
        "end": "00:00:04,800",
        "text": "إِنَّ هَذَا الْبَيْتَ بَيْتُكَ"
      },
      {
        "start": "00:00:04,800",
        "end": "00:00:07,000",
        "text": "وَالْحَرَمَ حَرَمُكَ"
      },
      {
        "start": "00:00:07,000",
        "end": "00:00:09,200",
        "text": "وَالْأَمْنَ أَمْنُكَ"
      },
      {
        "start": "00:00:09,200",
        "end": "00:00:11,400",
        "text": "وَالْعَبْدَ عَبْدُكَ"
      },
      {
        "start": "00:00:11,400",
        "end": "00:00:13,600",
        "text": "وَأَنَا عَبْدُكَ"
      },
      {
        "start": "00:00:13,600",
        "end": "00:00:15,800",
        "text": "وَابْنُ عَبْدِكَ"
      },
      {
        "start": "00:00:15,800",
        "end": "00:00:18,500",
        "text": "وَابْنُ أَمَتِكَ"
      },
      {
        "start": "00:00:18,500",
        "end": "00:00:23,000",
        "text": "وَهَذَا مَقَامُ الْعَائِذِ بِكَ مِنَ النَّارِ"
      },
      {
        "start": "00:00:23,000",
        "end": "00:00:25,500",
        "text": "فَحَرِّمْ لُحُومَنَا"
      },
      {
        "start": "00:00:25,500",
        "end": "00:00:28,500",
        "text": "وَبَشَرَتَنَا عَلَى النَّارِ"
      },
      {
        "start": "00:00:28,500",
        "end": "00:00:30,200",
        "text": "اللَّهُمَّ"
      },
      {
        "start": "00:00:30,200",
        "end": "00:00:33,200",
        "text": "حَبِّبْ إِلَيْنَا الْإِيمَانَ"
      },
      {
        "start": "00:00:33,200",
        "end": "00:00:35,700",
        "text": "وَزَيِّنْهُ فِي قُلُوبِنَا"
      },
      {
        "start": "00:00:35,700",
        "end": "00:00:38,200",
        "text": "وَكَرِّهْ إِلَيْنَا الْكُفْرَ"
      },
      {
        "start": "00:00:38,200",
        "end": "00:00:41,200",
        "text": "وَالْفُسُوقَ وَالْعِصْيَانَ"
      },
      {
        "start": "00:00:41,200",
        "end": "00:00:44,000",
        "text": "وَاجْعَلْنَا مِنَ الرَّاشِدِينَ"
      },
      {
        "start": "00:00:44,000",
        "end": "00:00:46,500",
        "text": "اللَّهُمَّ ارْزُقْنِي الْجَنَّةَ"
      },
      {
        "start": "00:00:46,500",
        "end": "00:00:48,500",
        "text": "بِغَيْرِ حِسَابٍ"
      }
    ],
    "tl": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,800",
        "text": "Allahumma"
      },
      {
        "start": "00:00:01,800",
        "end": "00:00:04,800",
        "text": "inna hadhal bayta baytuka"
      },
      {
        "start": "00:00:04,800",
        "end": "00:00:07,000",
        "text": "wal harama haramuka"
      },
      {
        "start": "00:00:07,000",
        "end": "00:00:09,200",
        "text": "wal amna amnuka"
      },
      {
        "start": "00:00:09,200",
        "end": "00:00:11,400",
        "text": "wal 'abda 'abduka"
      },
      {
        "start": "00:00:11,400",
        "end": "00:00:13,600",
        "text": "wa ana 'abduka"
      },
      {
        "start": "00:00:13,600",
        "end": "00:00:15,800",
        "text": "wabnu 'abdika"
      },
      {
        "start": "00:00:15,800",
        "end": "00:00:18,500",
        "text": "wabnu amatika"
      },
      {
        "start": "00:00:18,500",
        "end": "00:00:23,000",
        "text": "wa hadha maqamul 'aidhi bika minan-nar"
      },
      {
        "start": "00:00:23,000",
        "end": "00:00:25,500",
        "text": "fa harrim luhumana"
      },
      {
        "start": "00:00:25,500",
        "end": "00:00:28,500",
        "text": "wa basharatana 'alan-nar"
      },
      {
        "start": "00:00:28,500",
        "end": "00:00:30,200",
        "text": "Allahumma"
      },
      {
        "start": "00:00:30,200",
        "end": "00:00:33,200",
        "text": "habbib ilaynal iman"
      },
      {
        "start": "00:00:33,200",
        "end": "00:00:35,700",
        "text": "wa zayyinhu fi qulubina"
      },
      {
        "start": "00:00:35,700",
        "end": "00:00:38,200",
        "text": "wa karrih ilaynal kufra"
      },
      {
        "start": "00:00:38,200",
        "end": "00:00:41,200",
        "text": "wal fusuqa wal 'isyan"
      },
      {
        "start": "00:00:41,200",
        "end": "00:00:44,000",
        "text": "waj'alna minar-rashidin"
      },
      {
        "start": "00:00:44,000",
        "end": "00:00:46,500",
        "text": "Allahummar-zuqnil jannah"
      },
      {
        "start": "00:00:46,500",
        "end": "00:00:48,500",
        "text": "bi ghayri hisab"
      }
    ],
    "ms": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,800",
        "text": "Ya Allah"
      },
      {
        "start": "00:00:01,800",
        "end": "00:00:04,800",
        "text": "Sesungguhnya Baitullah ini adalah rumah-Mu"
      },
      {
        "start": "00:00:04,800",
        "end": "00:00:07,000",
        "text": "Dan Tanah Haram ini adalah milik-Mu"
      },
      {
        "start": "00:00:07,000",
        "end": "00:00:09,200",
        "text": "Dan keamanan ini adalah keamanan-Mu"
      },
      {
        "start": "00:00:09,200",
        "end": "00:00:11,400",
        "text": "Dan hamba ini adalah hamba-Mu"
      },
      {
        "start": "00:00:11,400",
        "end": "00:00:13,600",
        "text": "Dan aku adalah hamba-Mu"
      },
      {
        "start": "00:00:13,600",
        "end": "00:00:15,800",
        "text": "Anak kepada hamba-Mu (lelaki)"
      },
      {
        "start": "00:00:15,800",
        "end": "00:00:18,500",
        "text": "Anak kepada hamba-Mu (perempuan)"
      },
      {
        "start": "00:00:18,500",
        "end": "00:00:23,000",
        "text": "Dan inilah tempat orang yang memohon perlindungan-Mu daripada api neraka"
      },
      {
        "start": "00:00:23,000",
        "end": "00:00:25,500",
        "text": "Maka haramkanlah daging kami"
      },
      {
        "start": "00:00:25,500",
        "end": "00:00:28,500",
        "text": "Dan kulit kami daripada api neraka"
      },
      {
        "start": "00:00:28,500",
        "end": "00:00:30,200",
        "text": "Ya Allah"
      },
      {
        "start": "00:00:30,200",
        "end": "00:00:33,200",
        "text": "Cintakanlah kami kepada iman"
      },
      {
        "start": "00:00:33,200",
        "end": "00:00:35,700",
        "text": "Dan hiaskannya di dalam hati kami"
      },
      {
        "start": "00:00:35,700",
        "end": "00:00:38,200",
        "text": "Dan bencikanlah kami kepada kekufuran"
      },
      {
        "start": "00:00:38,200",
        "end": "00:00:41,200",
        "text": "Kefasikan dan kederhakaan"
      },
      {
        "start": "00:00:41,200",
        "end": "00:00:44,000",
        "text": "Dan jadikanlah kami daripada golongan yang mendapat petunjuk"
      },
      {
        "start": "00:00:44,000",
        "end": "00:00:46,500",
        "text": "Ya Allah, kurniakanlah aku syurga"
      },
      {
        "start": "00:00:46,500",
        "end": "00:00:48,500",
        "text": "Tanpa hisab"
      }
    ],
    "en": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,800",
        "text": "O Allah"
      },
      {
        "start": "00:00:01,800",
        "end": "00:00:04,800",
        "text": "Indeed, this House is Your House"
      },
      {
        "start": "00:00:04,800",
        "end": "00:00:07,000",
        "text": "And this Sacred Precinct is Your Sanctuary"
      },
      {
        "start": "00:00:07,000",
        "end": "00:00:09,200",
        "text": "And this safety is Your security"
      },
      {
        "start": "00:00:09,200",
        "end": "00:00:11,400",
        "text": "And every slave is Your slave"
      },
      {
        "start": "00:00:11,400",
        "end": "00:00:13,600",
        "text": "And I am Your slave"
      },
      {
        "start": "00:00:13,600",
        "end": "00:00:15,800",
        "text": "The son of Your male servant"
      },
      {
        "start": "00:00:15,800",
        "end": "00:00:18,500",
        "text": "The son of Your female servant"
      },
      {
        "start": "00:00:18,500",
        "end": "00:00:23,000",
        "text": "And this is the place of one who seeks refuge in You from the Fire"
      },
      {
        "start": "00:00:23,000",
        "end": "00:00:25,500",
        "text": "So forbid our flesh"
      },
      {
        "start": "00:00:25,500",
        "end": "00:00:28,500",
        "text": "And our skin to the Fire"
      },
      {
        "start": "00:00:28,500",
        "end": "00:00:30,200",
        "text": "O Allah"
      },
      {
        "start": "00:00:30,200",
        "end": "00:00:33,200",
        "text": "Make faith beloved to us"
      },
      {
        "start": "00:00:33,200",
        "end": "00:00:35,700",
        "text": "And beautify it in our hearts"
      },
      {
        "start": "00:00:35,700",
        "end": "00:00:38,200",
        "text": "And make hateful to us disbelief"
      },
      {
        "start": "00:00:38,200",
        "end": "00:00:41,200",
        "text": "Wickedness, and disobedience"
      },
      {
        "start": "00:00:41,200",
        "end": "00:00:44,000",
        "text": "And make us among the rightly guided"
      },
      {
        "start": "00:00:44,000",
        "end": "00:00:46,500",
        "text": "O Allah, grant me Paradise"
      },
      {
        "start": "00:00:46,500",
        "end": "00:00:48,500",
        "text": "Without account"
      }
    ],
    "ml": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,800",
        "text": "അല്ലാഹുവേ"
      },
      {
        "start": "00:00:01,800",
        "end": "00:00:04,800",
        "text": "നിശ്ചയമായും ഈ മന്ദിരം നിന്റേതാണ്"
      },
      {
        "start": "00:00:04,800",
        "end": "00:00:07,000",
        "text": "ഈ ഹറം നിന്റേതാണ്"
      },
      {
        "start": "00:00:07,000",
        "end": "00:00:09,200",
        "text": "ഈ അഭയം നിന്റേതാണ്"
      },
      {
        "start": "00:00:09,200",
        "end": "00:00:11,400",
        "text": "ഈ അടിമ നിന്റെ അടിമയാണ്"
      },
      {
        "start": "00:00:11,400",
        "end": "00:00:13,600",
        "text": "ഞാൻ നിന്റെ അടിമയാണ്"
      },
      {
        "start": "00:00:13,600",
        "end": "00:00:15,800",
        "text": "നിന്റെ അടിമയുടെ മകൻ"
      },
      {
        "start": "00:00:15,800",
        "end": "00:00:18,500",
        "text": "നിന്റെ ദാസിയുടെ മകൻ"
      },
      {
        "start": "00:00:18,500",
        "end": "00:00:23,000",
        "text": "നരകത്തിൽ നിന്നും നിന്നോട് അഭയം തേടുന്നവന്റെ സ്ഥാനമാണിത്"
      },
      {
        "start": "00:00:23,000",
        "end": "00:00:25,500",
        "text": "അതുകൊണ്ട് ഞങ്ങളുടെ മാംസത്തെ"
      },
      {
        "start": "00:00:25,500",
        "end": "00:00:28,500",
        "text": "ഞങ്ങളുടെ ചർമ്മത്തെ നരകത്തിന് നിഷിദ്ധമാക്കേണമേ"
      },
      {
        "start": "00:00:28,500",
        "end": "00:00:30,200",
        "text": "അല്ലാഹുവേ"
      },
      {
        "start": "00:00:30,200",
        "end": "00:00:33,200",
        "text": "ഈമാൻ ഞങ്ങൾക്ക് പ്രിയങ്കരമാക്കേണമേ"
      },
      {
        "start": "00:00:33,200",
        "end": "00:00:35,700",
        "text": "അത് ഞങ്ങളുടെ ഹൃദയങ്ങളിൽ അലംകൃതമാക്കേണമേ"
      },
      {
        "start": "00:00:35,700",
        "end": "00:00:38,200",
        "text": "കുഫ്റിനെയും അധർമ്മത്തെയും"
      },
      {
        "start": "00:00:38,200",
        "end": "00:00:41,200",
        "text": "അനുസരണക്കേടിനെയും ഞങ്ങളിൽ വെറുപ്പുള്ളതാക്കേണമേ"
      },
      {
        "start": "00:00:41,200",
        "end": "00:00:44,000",
        "text": "ഞങ്ങളെ സന്മാർഗ്ഗികളിൽ ഉൾപ്പെടുത്തേണമേ"
      },
      {
        "start": "00:00:44,000",
        "end": "00:00:46,500",
        "text": "അല്ലാഹുവേ, എനിക്ക് സ്വർഗ്ഗം നൽകേണമേ"
      },
      {
        "start": "00:00:46,500",
        "end": "00:00:48,500",
        "text": "യാതൊരു വിചാരണയും കൂടാതെ"
      }
    ],
    "ta": [
      {
        "start": "00:00:00,000",
        "end": "00:00:01,800",
        "text": "யா அல்லாஹ்"
      },
      {
        "start": "00:00:01,800",
        "end": "00:00:04,800",
        "text": "நிச்சயமாக இந்த இல்லம் உன்னுடைய இல்லம்"
      },
      {
        "start": "00:00:04,800",
        "end": "00:00:07,000",
        "text": "இந்த ஹரம் உன்னுடைய ஹரம்"
      },
      {
        "start": "00:00:07,000",
        "end": "00:00:09,200",
        "text": "இந்த அபயம் உன்னுடைய அபயம்"
      },
      {
        "start": "00:00:09,200",
        "end": "00:00:11,400",
        "text": "இந்த அடியான் உன்னுடைய அடியான்"
      },
      {
        "start": "00:00:11,400",
        "end": "00:00:13,600",
        "text": "நானும் உன்னுடைய அடியான்"
      },
      {
        "start": "00:00:13,600",
        "end": "00:00:15,800",
        "text": "உன் அடியானின் மகன்"
      },
      {
        "start": "00:00:15,800",
        "end": "00:00:18,500",
        "text": "உன் அடிமைப் பெண்ணின் மகன்"
      },
      {
        "start": "00:00:18,500",
        "end": "00:00:23,000",
        "text": "நரகத்தை விட்டு உன்னிடம் பாதுகாப்புத் தேடுபவன் நிற்கும் இடம் இது"
      },
      {
        "start": "00:00:23,000",
        "end": "00:00:25,500",
        "text": "எங்கள் மாமிசத்தை"
      },
      {
        "start": "00:00:25,500",
        "end": "00:00:28,500",
        "text": "எங்கள் சருமத்தை நரகத்திற்கு ஹராமாக்குவாயாக"
      },
      {
        "start": "00:00:28,500",
        "end": "00:00:30,200",
        "text": "யா அல்லாஹ்"
      },
      {
        "start": "00:00:30,200",
        "end": "00:00:33,200",
        "text": "ஈமானை எங்களுக்குப் பிரியமானதாக்கு"
      },
      {
        "start": "00:00:33,200",
        "end": "00:00:35,700",
        "text": "அதை எங்கள் இதயங்களில் அழகாக்கு"
      },
      {
        "start": "00:00:35,700",
        "end": "00:00:38,200",
        "text": "குஃப்ரு, பாவம் மற்றும்"
      },
      {
        "start": "00:00:38,200",
        "end": "00:00:41,200",
        "text": "மாறு செய்வதை எங்களுக்கு வெறுப்பாக்கு"
      },
      {
        "start": "00:00:41,200",
        "end": "00:00:44,000",
        "text": "நேர்வழி பெற்றவர்களில் எங்களைச் சேர்த்துவிடு"
      },
      {
        "start": "00:00:44,000",
        "end": "00:00:46,500",
        "text": "யா அல்லாஹ், எனக்கு சொர்க்கத்தை வழங்கு"
      },
      {
        "start": "00:00:46,500",
        "end": "00:00:48,500",
        "text": "எந்த விசாரணையுமின்றி"
      }
    ]
  }
}